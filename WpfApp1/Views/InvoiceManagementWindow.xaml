<Window x:Class="FashionStore.InvoiceManagementWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:oxy="http://oxyplot.org/wpf"
        xmlns:local="clr-namespace:FashionStore"
        Title="Quản Lý Hóa Đơn" Height="800" Width="1280"
        WindowStartupLocation="CenterScreen">
    
    <Window.InputBindings>
        <KeyBinding Key="Enter" Command="{Binding AddItemCommand}"/>
        <KeyBinding Key="S" Modifiers="Control" Command="{Binding SaveInvoiceCommand}"/>
    </Window.InputBindings>
    
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </Window.Resources>

	<Grid Background="#F5F5F5" PreviewMouseWheel="Grid_PreviewMouseWheel">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="*"/>
			<RowDefinition Height="Auto"/>
		</Grid.RowDefinitions>

		<!-- Header -->
		<Border Grid.Row="0" Background="#1CB5E0" Padding="20">
			<Grid>
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="*"/>
					<ColumnDefinition Width="Auto"/>
				</Grid.ColumnDefinitions>
				<StackPanel Orientation="Horizontal" VerticalAlignment="Center">
					<TextBlock Text="🧾 Quản Lý Hóa Đơn" FontSize="26" FontWeight="Bold" Foreground="White"/>
					<TextBlock Text=" - Tạo hóa đơn bán hàng" FontSize="14" Foreground="#B3E5FC" Margin="10,0,0,0"/>
                </StackPanel>
				<StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
					<TextBlock Text="👤 Khách hàng:" Foreground="White" VerticalAlignment="Center" FontWeight="SemiBold"/>
					<Grid Width="280" Height="32" Margin="8,0,0,0">
						<TextBox x:Name="CustomerSearchTextBox"
						         Height="32"
						         FontSize="14"
						         VerticalContentAlignment="Center"
						         Text="{Binding CustomerSearchText, UpdateSourceTrigger=PropertyChanged}"
						         ToolTip="Gõ tên / SĐT để tìm khách hàng"/>
						<Popup x:Name="CustomerSuggestionsPopup"
						       PlacementTarget="{Binding ElementName=CustomerSearchTextBox}"
						       Placement="Bottom"
						       StaysOpen="False"
						       AllowsTransparency="False"
						       PopupAnimation="Fade"
                               IsOpen="{Binding IsCustomerPopupOpen, Mode=TwoWay}">
							<Border Background="White" BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="6" Padding="4">
								<ListBox x:Name="CustomerSuggestionsListBox"
								         Width="{Binding ElementName=CustomerSearchTextBox, Path=ActualWidth}"
								         MaxHeight="240"
                                         ItemsSource="{Binding FilteredCustomers}"
                                         SelectedItem="{Binding SelectedCustomer, Mode=TwoWay}"
								         PreviewMouseWheel="ListBox_PreviewMouseWheel">
									<ListBox.ItemTemplate>
										<DataTemplate>
											<StackPanel Orientation="Horizontal">
												<TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
												<TextBlock Text="  •  " Foreground="#999"/>
												<TextBlock Text="{Binding Phone}" Foreground="#666666"/>
											</StackPanel>
										</DataTemplate>
									</ListBox.ItemTemplate>
								</ListBox>
							</Border>
						</Popup>
					</Grid>
					<Button Content="📜 Lịch sử" Width="120" Height="32" Margin="12,0,0,0" 
							Background="#FF9800" Foreground="White" FontWeight="SemiBold" Command="{Binding OpenHistoryCommand}"/>
					<Border Background="#1496C6" CornerRadius="6" Padding="8,4" Margin="12,0,0,0" VerticalAlignment="Center">
						<StackPanel Orientation="Horizontal" VerticalAlignment="Center">
							<TextBlock Text="🏷️ " Foreground="White"/>
							<TextBlock Text="{Binding LoyaltyTierText}" Foreground="White" FontWeight="Bold"/>
							<TextBlock Text=" • " Foreground="#B3E5FC"/>
							<TextBlock Text="{Binding LoyaltyPointsText}" Foreground="#B3E5FC"/>
						</StackPanel>
					</Border>
				</StackPanel>
			</Grid>
		</Border>

		<!--Main Content -->
		<Grid Grid.Row="1" Margin="20">
			<Grid.RowDefinitions>
				<RowDefinition Height="Auto"/>
				<RowDefinition Height="*"/>
				<RowDefinition Height="200"/>
			</Grid.RowDefinitions>
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="*"/>
				<ColumnDefinition Width="380"/>
			</Grid.ColumnDefinitions>

			<!-- Product selector -->
			<Border Grid.Row="0" Background="White" CornerRadius="12" Padding="16" Margin="0,0,0,12" BorderBrush="#E0E0E0" BorderThickness="1">
				<Grid>
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="*"/>
						<ColumnDefinition Width="100"/>
						<ColumnDefinition Width="120"/>
						<ColumnDefinition Width="Auto"/>
					</Grid.ColumnDefinitions>
					<StackPanel Grid.Column="0" Margin="0,0,12,0">
						<TextBlock Text="🔍 Chọn sản phẩm" FontWeight="SemiBold" Margin="0,0,0,4" Foreground="#333"/>
						<ComboBox x:Name="ProductComboBox" Height="36" IsEditable="True" StaysOpenOnEdit="True"
								DisplayMemberPath="Name"
                                ItemsSource="{Binding Products}"
                                SelectedItem="{Binding SelectedProduct, Mode=TwoWay}"
								IsTextSearchEnabled="True" FontSize="14" Padding="8,6" ToolTip="Gõ để tìm sản phẩm theo tên hoặc mã"/>
					</StackPanel>
					<StackPanel Grid.Column="1" Margin="0,0,8,0" VerticalAlignment="Bottom">
						<TextBlock Text="📦 Số lượng" FontWeight="SemiBold" Margin="0,0,0,4" Foreground="#333"/>
						<TextBox Height="36" Text="{Binding QuantityText, UpdateSourceTrigger=PropertyChanged}" FontSize="14" Padding="8,6" TextAlignment="Center" ToolTip="Số lượng"/>
					</StackPanel>
					<StackPanel Grid.Column="2" Margin="0,0,8,0" VerticalAlignment="Bottom">
						<TextBlock Text="💰 Đơn giá" FontWeight="SemiBold" Margin="0,0,0,4" Foreground="#333"/>
						<TextBox Height="36" FontSize="14" Padding="8,6" TextAlignment="Right" ToolTip="Đơn giá bán" Text="{Binding UnitPriceText, UpdateSourceTrigger=PropertyChanged}"/>
					</StackPanel>
					<Button Grid.Column="3" Content="➕ Thêm vào hóa đơn" Width="180" Height="40" 
							Background="#4CAF50" Foreground="White" FontWeight="SemiBold" FontSize="14" 
							Command="{Binding AddItemCommand}" VerticalAlignment="Bottom" ToolTip="Thêm sản phẩm vào hóa đơn (Enter)"/>
				</Grid>
			</Border>

			<!-- Items grid -->
			<Border Grid.Row="1" Background="White" CornerRadius="12" BorderBrush="#E0E0E0" BorderThickness="1">
				<Grid>
					<Grid.RowDefinitions>
						<RowDefinition Height="Auto"/>
						<RowDefinition Height="*"/>
					</Grid.RowDefinitions>
					
					<!-- Grid Header -->
					<Border Grid.Row="0" Background="#1CB5E0" CornerRadius="12,12,0,0" Padding="16,12">
						<Grid>
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="*"/>
								<ColumnDefinition Width="Auto"/>
							</Grid.ColumnDefinitions>
							<TextBlock Text="🛒 Danh sách sản phẩm" FontSize="16" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
							<StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
								<TextBlock Text="Tổng:" Foreground="White" FontWeight="SemiBold" Margin="0,0,5,0"/>
								<TextBlock Text="{Binding ItemCountText}" Foreground="White" FontWeight="Bold"/>
							</StackPanel>
						</Grid>
					</Border>
					
					<DataGrid Grid.Row="1"
					          x:Name="InvoiceItemsDataGrid"
					          AutoGenerateColumns="False"
					          CanUserAddRows="False"
					          SelectionMode="Single"
					          Background="White"
					          RowHeaderWidth="0"
					          EnableRowVirtualization="True"
					          EnableColumnVirtualization="False"
					          BorderThickness="0"
					          GridLinesVisibility="Horizontal"
					          HeadersVisibility="Column"
					          MinHeight="400"
                              ItemsSource="{Binding InvoiceItems}"
					          PreviewMouseWheel="ListBox_PreviewMouseWheel">
				<DataGrid.Resources>
					<Style TargetType="TextBlock" x:Key="RightAlignedCell">
						<Setter Property="TextAlignment" Value="Right"/>
					</Style>
				</DataGrid.Resources>
				<DataGrid.Columns>
 					<DataGridTextColumn Header="#" Binding="{Binding RowNumber}" Width="40" MinWidth="30" IsReadOnly="True"/>
 					<DataGridTextColumn Header="Sản phẩm" Binding="{Binding ProductName}" Width="*" MinWidth="150" IsReadOnly="True"/>
 					<DataGridTextColumn Header="Giá bán" Binding="{Binding UnitPrice, StringFormat=N0}" Width="100" MinWidth="90" IsReadOnly="True">
 						<DataGridTextColumn.ElementStyle>
 							<Style TargetType="TextBlock">
 								<Setter Property="TextAlignment" Value="Right"/>
 							</Style>
 						</DataGridTextColumn.ElementStyle>
 					</DataGridTextColumn>
 					<DataGridTextColumn Header="KM%" Binding="{Binding PromoDiscountPercent, StringFormat=N2}" Width="65" MinWidth="60" IsReadOnly="True">
 						<DataGridTextColumn.ElementStyle>
 							<Style TargetType="TextBlock">
 								<Setter Property="TextAlignment" Value="Right"/>
 								<Setter Property="FontWeight" Value="Bold"/>
 								<Setter Property="Foreground" Value="#E91E63"/>
 							</Style>
 						</DataGridTextColumn.ElementStyle>
 					</DataGridTextColumn>
 					<DataGridTextColumn Header="SL" Binding="{Binding Quantity}" Width="50" MinWidth="45" IsReadOnly="True">
 						<DataGridTextColumn.ElementStyle>
 							<Style TargetType="TextBlock">
 								<Setter Property="TextAlignment" Value="Right"/>
 							</Style>
 						</DataGridTextColumn.ElementStyle>
 					</DataGridTextColumn>
 					<DataGridTextColumn Header="T.Tiền" Binding="{Binding LineTotal, StringFormat=N0}" Width="110" MinWidth="100" IsReadOnly="True">
 						<DataGridTextColumn.ElementStyle>
 							<Style TargetType="TextBlock">
 								<Setter Property="TextAlignment" Value="Right"/>
 							</Style>
 						</DataGridTextColumn.ElementStyle>
 					</DataGridTextColumn>
 					<DataGridTextColumn Header="Thuế" Binding="{Binding CategoryTaxPercent, StringFormat=N2}" Width="65" MinWidth="60" IsReadOnly="True">
 						<DataGridTextColumn.ElementStyle>
 							<Style TargetType="TextBlock">
 								<Setter Property="TextAlignment" Value="Right"/>
 							</Style>
 						</DataGridTextColumn.ElementStyle>
 					</DataGridTextColumn>
 					<DataGridTemplateColumn Header="⚙️" Width="130" MinWidth="110">
						<DataGridTemplateColumn.CellTemplate>
							<DataTemplate>
								<StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
									<Button Content="➕" Width="30" Height="28" Margin="0,0,4,0" 
											Background="#4CAF50" Foreground="White" FontWeight="Bold" Command="{Binding DataContext.IncreaseQtyCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" CommandParameter="{Binding}"/>
									<Button Content="➖" Width="30" Height="28" Margin="0,0,4,0" 
											Background="#FF9800" Foreground="White" FontWeight="Bold" Command="{Binding DataContext.DecreaseQtyCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" CommandParameter="{Binding}"/>
									<Button Content="🗑️" Width="40" Height="28" 
											Background="#F44336" Foreground="White" FontWeight="Bold" Command="{Binding DataContext.RemoveItemCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" CommandParameter="{Binding}"/>
								</StackPanel>
							</DataTemplate>
						</DataGridTemplateColumn.CellTemplate>
					</DataGridTemplateColumn>
				</DataGrid.Columns>
			</DataGrid>
				</Grid>
			</Border>


			<Border Grid.Row="0" Grid.Column="1" Grid.RowSpan="3" Background="White" CornerRadius="0" Padding="20" Margin="12,0,0,0" BorderBrush="#E0E0E0" BorderThickness="1">
				<Grid>
					<Grid.RowDefinitions>
						<RowDefinition Height="Auto"/>
						<RowDefinition Height="*"/>
					</Grid.RowDefinitions>
					
					<!-- Summary Header -->
					<Border Grid.Row="0" Background="#1CB5E0" CornerRadius="8" Padding="12" Margin="0,0,0,15">
						<TextBlock Text="💰 Tổng Kết Hóa Đơn" FontSize="16" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
					</Border>
					
					<!-- Totals Content -->
					<ScrollViewer x:Name="TotalsScrollViewer" Grid.Row="1" VerticalScrollBarVisibility="Auto" PreviewMouseWheel="ScrollViewer_PreviewMouseWheel">
						<Border Background="#F8F9FA" CornerRadius="8" Padding="16">
						<Grid>
							<Grid.RowDefinitions>
								<RowDefinition Height="Auto"/>
								<RowDefinition Height="Auto"/>
								<RowDefinition Height="Auto"/>
								<RowDefinition Height="Auto"/>
								<RowDefinition Height="Auto"/>
								<RowDefinition Height="Auto"/>
								<RowDefinition Height="Auto"/>
								<RowDefinition Height="Auto"/>
								<RowDefinition Height="Auto"/>
								<RowDefinition Height="Auto"/>
								<RowDefinition Height="Auto"/>
							</Grid.RowDefinitions>
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="*"/>
								<ColumnDefinition Width="120"/>
							</Grid.ColumnDefinitions>

							<TextBlock Grid.Row="0" Grid.Column="0" Text="💰 Tạm tính:" HorizontalAlignment="Left" Margin="0,0,8,8" FontWeight="SemiBold"/>
							<TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SubtotalText}" HorizontalAlignment="Left" TextAlignment="Left" FontSize="16" FontWeight="Bold" Foreground="#2E7D32"/>

							<StackPanel Grid.Row="1" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,8,0,8" Height="auto">
								<TextBlock Text="📊 Thuế (tự động theo danh mục):" VerticalAlignment="Center" FontWeight="SemiBold"/>
								<TextBlock Text="Thuế:" VerticalAlignment="Center" Margin="12,0,0,0" FontWeight="SemiBold"/>
								<TextBlock Text="{Binding TaxAmountText}" Width="80" TextAlignment="Left" Margin="6,0,0,0" FontWeight="Bold"/>
							</StackPanel>

							<!-- Voucher Selection -->
							<StackPanel Grid.Row="2" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,8,0,0">
								<TextBlock Text="🎟️ Voucher:" VerticalAlignment="Center" FontWeight="SemiBold"/>
								<ComboBox x:Name="VoucherComboBox" Width="180" Height="28" Margin="6,0,0,0" 
										  DisplayMemberPath="Code"
                                          ItemsSource="{Binding Vouchers}" SelectedItem="{Binding SelectedVoucher, Mode=TwoWay}"
										  ToolTip="Chọn mã giảm giá"/>
							</StackPanel>

							<StackPanel Grid.Row="3" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,8,0,8">
								<TextBlock Text="🎁 Giảm giá:" VerticalAlignment="Center" FontWeight="SemiBold"/>
							<ComboBox x:Name="DiscountModeComboBox" Width="70" Height="28" Margin="6,0,0,0" ItemsSource="{Binding DiscountModes}" SelectedItem="{Binding SelectedDiscountMode, Mode=TwoWay}"/>
								<TextBox Width="80" Height="28" Margin="6,0,0,0" TextAlignment="Center" Text="{Binding DiscountValueText, UpdateSourceTrigger=PropertyChanged}"/>
								
							</StackPanel>
                            <StackPanel Grid.Row="4" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,0,0,8">
                            <TextBlock Text="{Binding TierDiscountInlineText}" Margin="8,0,0,0" Foreground="#4CAF50" FontWeight="SemiBold"/>
                            </StackPanel>
                            <Border Grid.Row="5" Grid.ColumnSpan="2" Background="#E0E0E0" Height="1" Margin="0,0,0,8"/>

							<TextBlock Grid.Row="6" Grid.Column="0" Text="💵 Tổng cộng:" HorizontalAlignment="Left" FontWeight="Bold" FontSize="16" Margin="0,0,8,8" Foreground="#D32F2F"/>
							<TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding TotalText}" HorizontalAlignment="Left" TextAlignment="Left" FontWeight="Bold" FontSize="22" Foreground="#D32F2F"/>

							<StackPanel Grid.Row="7" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,8,0,8">
								<TextBlock Text="💳 PTTT:" VerticalAlignment="Center" FontWeight="SemiBold"/>
								<ComboBox x:Name="PaymentMethodComboBox" Width="100" Height="28" Margin="6,0,12,0" FontSize="12" ItemsSource="{Binding PaymentMethods}" SelectedItem="{Binding SelectedPaymentMethod, Mode=TwoWay}"/>
								<TextBlock Text="Đã trả:" VerticalAlignment="Center" FontWeight="SemiBold"/>
								<TextBox Width="70" Height="28" Margin="6,0,0,0" TextAlignment="Center" Text="{Binding PaidText, UpdateSourceTrigger=PropertyChanged}"/>
							</StackPanel>

							<StackPanel Grid.Row="8" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,8,0,12">
								<TextBlock Text="🔄 Tiền thừa:" VerticalAlignment="Center" FontWeight="Bold"/>
								<TextBlock Text="{Binding ChangeText}" Width="80" TextAlignment="Left" Margin="6,0,0,0" FontWeight="Bold" Foreground="#388E3C"/>
							</StackPanel>

							<!-- QR Code Section -->
                            <Border Grid.Row="9" Grid.ColumnSpan="2" Background="#FFFFFF" CornerRadius="10" Padding="12" Margin="0,0,0,8" 
									BorderBrush="#4CAF50" BorderThickness="2" Width="260">
								<Grid>
									<Grid.RowDefinitions>
										<RowDefinition Height="45"/>
										<RowDefinition Height="*"/>
									</Grid.RowDefinitions>

									<!-- Header -->
									<Border Grid.Row="0" Background="#4CAF50" CornerRadius="6" Padding="8" Margin="0,0,0,10">
										<StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
											<TextBlock Text="💳" FontSize="20" VerticalAlignment="Center" Margin="0,0,6,0"/>
											<TextBlock Text="QUÉT MÃ THANH TOÁN" FontSize="13" FontWeight="Bold"
													   Foreground="White"/>
										</StackPanel>
									</Border>

									<!-- QR Code Image -->
									<Border Grid.Row="1" Background="#F5F5F5" CornerRadius="8" Padding="10" 
											BorderBrush="#E0E0E0" BorderThickness="2" MinHeight="200"> 
											<StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
											<Image x:Name="InvoiceQRCode" Width="200" Height="200"
												   Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   Source="{Binding QRCodeImage}" Visibility="{Binding IsQRCodeVisible, Converter={StaticResource BooleanToVisibilityConverter}}"/>
											<TextBlock Text="{Binding QRPlaceholderText}" FontSize="10"
													   Foreground="#9E9E9E" HorizontalAlignment="Center" TextAlignment="Center"
													   Margin="0,8,0,0" TextWrapping="Wrap"
                                                       Visibility="{Binding IsQRPlaceholderVisible, Converter={StaticResource BooleanToVisibilityConverter}}"/>
										</StackPanel>
									</Border>
								</Grid>
							</Border>
							
							<StackPanel Grid.Row="10" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,0">
								<Button Content="💾 Lưu Hóa Đơn" Width="140" Height="40" 
										Background="#4CAF50" Foreground="White" FontWeight="SemiBold" Command="{Binding SaveInvoiceCommand}" Margin="0,0,8,0"/>
								<Button Content="🧹 Xóa Hóa Đơn" Width="140" Height="40"
										Background="#9E9E9E" Foreground="White" FontWeight="SemiBold" Command="{Binding ClearInvoiceCommand}" Margin="0,0,0,0"/>
							</StackPanel>
						</Grid>
					</Border>
					</ScrollViewer>
				</Grid>
			</Border>
		</Grid>
	</Grid>
</Window>
