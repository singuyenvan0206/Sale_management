<Window x:Class="FashionStore.ChangePasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:FashionStore"
        Title="Đổi Mật Khẩu" Height="580" Width="720" 
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5"
        ResizeMode="CanResize"
        MinHeight="520" MinWidth="580">
    
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
    </Window.Resources>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <Border Grid.Row="0" Background="#D6336C" Padding="20">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="🔐" FontSize="24" Margin="0,0,12,0"/>
                <StackPanel>
                    <TextBlock Text="ĐỔI MẬT KHẨU" 
                               FontSize="20" 
                               FontWeight="Bold" 
                               Foreground="White"/>
                    <TextBlock Text="Cập nhật mật khẩu tài khoản của bạn" 
                               FontSize="12" 
                               Foreground="#FFE6F0" 
                               Margin="0,2,0,0"/>
                </StackPanel>
            </StackPanel>
        </Border>
        
        <!-- Main Content -->
        <Border Grid.Row="1" Background="White" Margin="20" CornerRadius="12" Padding="30">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <Grid MaxWidth="900">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2.3*"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Form -->
                    <StackPanel Grid.Column="0" Margin="0,0,20,0">
                        <TextBlock Text="Thông tin tài khoản" 
                                   FontSize="16" 
                                   FontWeight="Bold" 
                                   Foreground="#263238" 
                                   Margin="0,0,0,15"/>

                        <UniformGrid Rows="4" Columns="1" Margin="0,0,0,25">
                            <StackPanel Margin="0,10,0,0">
                                <TextBlock Text="Tên đăng nhập" FontWeight="SemiBold" FontSize="15" Foreground="#37474F" Margin="0,0,0,10"/>
                                <TextBox x:Name="UsernameTextBox" Height="45" HorizontalAlignment="Stretch"/>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="Mật khẩu hiện tại" FontWeight="SemiBold" FontSize="15" Foreground="#37474F" Margin="0,0,0,10"/>
                                <PasswordBox x:Name="OldPasswordBox" Height="45" HorizontalAlignment="Stretch"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,0,15">
                                <TextBlock Text="Mật khẩu mới" FontWeight="SemiBold" FontSize="15" Foreground="#37474F" Margin="0,0,0,10"/>
                                <PasswordBox x:Name="NewPasswordBox" Height="45" HorizontalAlignment="Stretch"/>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="Xác nhận mật khẩu mới" FontWeight="SemiBold" FontSize="15" Foreground="#37474F" Margin="0,0,0,10"/>
                                <PasswordBox x:Name="ConfirmPasswordBox" Height="45" HorizontalAlignment="Stretch"/>
                            </StackPanel>
                        </UniformGrid>

                        <Border Background="#ECEFF1" BorderBrush="#CFD8DC" BorderThickness="1" CornerRadius="8" Padding="15" Margin="0,0,0,25">
                            <StackPanel>
                                <TextBlock Text="📌 Lưu ý bảo mật" FontWeight="Bold" FontSize="13" Foreground="#455A64" Margin="0,0,0,8"/>
                                <TextBlock Text="• Không chia sẻ mật khẩu cho người khác" FontSize="12" Foreground="#666" Margin="0,0,0,4"/>
                                <TextBlock Text="• Nên thay đổi mật khẩu định kỳ" FontSize="12" Foreground="#666"/>
                            </StackPanel>
                        </Border>

                        <UniformGrid Columns="2" Margin="0,10,0,0" HorizontalAlignment="Stretch">
                            <Button Content="🔄 Đổi Mật Khẩu" Height="45" Background="#4CAF50" Click="ChangePassword_Click" Margin="0,0,10,0"/>
                            <Button Content="❌ Hủy" Height="45" Background="#F44336" Click="Cancel_Click" Margin="10,0,0,0"/>
                        </UniformGrid>
                    </StackPanel>

                    <Border Grid.Column="1" Background="#FFF3E0" BorderBrush="#FFB300" BorderThickness="1" CornerRadius="10" Padding="18" HorizontalAlignment="Stretch">
                        <StackPanel>
                            <TextBlock Text="💡 Yêu cầu mật khẩu" FontWeight="Bold" FontSize="15" Foreground="#D84315" Margin="0,0,0,12"/>
                            <StackPanel Margin="0,0,0,20">
                                <TextBlock Text="• Tối thiểu 6 ký tự" FontSize="13" Foreground="#5D4037" Margin="0,0,0,4"/>
                                <TextBlock Text="• Phải khác mật khẩu hiện tại" FontSize="13" Foreground="#5D4037" Margin="0,0,0,4"/>
                                <TextBlock Text="• Hai mật khẩu mới phải giống nhau" FontSize="13" Foreground="#5D4037"/>
                            </StackPanel>
                            <Separator Margin="0,8"/>
                            <TextBlock Text="✅ Gợi ý" FontWeight="SemiBold" FontSize="13" Foreground="#5D4037" Margin="0,0,0,8"/>
                            <TextBlock Text="• Kết hợp chữ hoa, chữ thường, số và ký tự đặc biệt." FontSize="12" Foreground="#5D4037" TextWrapping="Wrap" Margin="0,0,0,6"/>
                            <TextBlock Text="• Tránh dùng thông tin cá nhân dễ đoán." FontSize="12" Foreground="#5D4037" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>
