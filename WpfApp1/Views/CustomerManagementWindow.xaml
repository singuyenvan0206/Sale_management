<Window x:Class="FashionStore.CustomerManagementWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:FashionStore"
        Title="Quản Lý Khách Hàng" Height="800" Width="1200"
        MinWidth="1200" MinHeight="800"
        WindowStartupLocation="CenterScreen">
    
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <Style TargetType="Button">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
    </Window.Resources>
    
    <Grid Background="#F5F5F5" PreviewMouseWheel="Grid_PreviewMouseWheel">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <Border Grid.Row="0" Background="#1CB5E0" Padding="20">
            <TextBlock Text="👥 Quản Lý Khách Hàng" FontSize="24" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
        </Border>
        <Grid Grid.Row="1" Margin="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="350"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Background="White" CornerRadius="10" Padding="20" Margin="0,0,10,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="Thông Tin Khách Hàng" FontSize="18" FontWeight="Bold" Foreground="#1CB5E0" Margin="0,0,0,20"/>
                        <TextBlock Text="Tên Khách Hàng *" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <TextBox Margin="0,0,0,15" Text="{Binding EditingCustomer.Name, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBlock Text="Số Điện Thoại *" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <TextBox Margin="0,0,0,15" Text="{Binding EditingCustomer.Phone, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBlock Text="Địa Chỉ Email" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <TextBox Margin="0,0,0,15" Text="{Binding EditingCustomer.Email, UpdateSourceTrigger=PropertyChanged}"/>

                        <TextBlock Text="Hạng thành viên" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <ComboBox IsEnabled="{Binding IsAdminOrManager}" Text="{Binding EditingCustomer.Tier, Mode=TwoWay}" Margin="0,0,0,10" x:Name="TierComboBox">
                            <ComboBoxItem Content="Regular"/>
                            <ComboBoxItem Content="Silver"/>
                            <ComboBoxItem Content="Gold"/>
                            <ComboBoxItem Content="Platinum"/>
                        </ComboBox>
                        <TextBlock Text="Điểm tích lũy" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <TextBox IsEnabled="{Binding IsAdminOrManager}" Text="{Binding EditingCustomer.Points, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,15"/>
                        <TextBlock Text="Địa Chỉ" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <TextBox Height="41" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" Margin="0,0,0,20" Text="{Binding EditingCustomer.Address, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBlock Text="Thao Tác" FontWeight="Bold" FontSize="16" Foreground="#1CB5E0" Margin="0,10,0,10"/>
                        <UniformGrid Columns="2" Margin="0,0,0,10">
                            <Button Content="➕ Thêm" Background="#4CAF50" Foreground="White" Command="{Binding AddCommand}" Margin="0,0,5,5"/>
                            <Button Content="✏️ Cập Nhật" Background="#2196F3" Foreground="White" Command="{Binding UpdateCommand}" Margin="5,0,0,5"/>
                        </UniformGrid>
                        <UniformGrid Columns="2" Margin="0,0,0,10">
                            <Button Content="🏆 Cập nhật hạng" Background="#9C27B0" Foreground="White" Command="{Binding UpdateLoyaltyCommand}" Margin="0,0,5,5"/>
                            <Button Content="🗑️ Xóa" Background="#F44336" Foreground="White" Command="{Binding DeleteCommand}" Margin="5,0,0,5"/>
                        </UniformGrid>
                        
                        <!-- Secondary Actions -->
                        <TextBlock Text="Quản Lý Dữ Liệu" FontWeight="Bold" FontSize="14" Foreground="#666" Margin="0,15,0,10"/>
                        <UniformGrid Columns="2" Margin="0,0,0,10">
                            <Button Content="📥 Nhập CSV" Background="#FF9800" Foreground="White" Command="{Binding ImportCsvCommand}" Margin="0,0,5,5"/>
                            <Button Content="📤 Xuất CSV" Background="#FF9800" Foreground="White" Command="{Binding ExportCsvCommand}" Margin="5,0,0,5"/>
                        </UniformGrid>
                        <Button Content="🗑️ Xóa Tất Cả" Background="#9E9E9E" Foreground="White" Command="{Binding DeleteAllCommand}" Margin="0,5,0,0"/>
                        <Button Content="🧹 Xóa Form" Background="#9E9E9E" Foreground="White" Command="{Binding ClearCommand}" Margin="0,10,0,0"/>

                        <!-- Status -->
                        <TextBlock Text="{Binding StatusText}" FontSize="12" Foreground="#666666" HorizontalAlignment="Center" Margin="0,15,0,0"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>
            
            <!-- Customer List with Tabs -->
            <Border Grid.Column="1" Background="White" CornerRadius="10" Padding="15">
                <TabControl>
                    <!-- Customer List Tab -->
                    <TabItem Header="📋 Danh Sách Khách Hàng" HorizontalAlignment="Right" Margin="0,-2,-2,0" Width="159">
                        <Grid Margin="10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            
                            <!-- Search Section -->
                            <Grid Grid.Row="0" Margin="0,0,0,15">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                
                                <TextBlock Grid.Row="0" Text="🔍 Tìm Kiếm Khách Hàng" FontSize="16" FontWeight="Bold" Foreground="#1CB5E0" Margin="0,0,0,10"/>
                                
                                <!-- Filter Panel -->
                                <Border Grid.Row="1" Background="#F8F9FA" Padding="12" Margin="0,0,0,10" CornerRadius="8">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        
                                        <TextBlock Grid.Row="0" Text="🔍 Lọc theo:" FontWeight="SemiBold" Margin="0,0,0,8" Foreground="#555"/>
                                        
                                        <Grid Grid.Row="1">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            
                                            <!-- Tier Filter -->
                                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                                <TextBlock Text="Hạng Thành Viên" FontSize="11" Foreground="#666" Margin="0,0,0,3"/>
                                                <ComboBox Height="32" x:Name="FilterTierComboBox" SelectedValuePath="Tag" SelectedValue="{Binding SelectedFilterTier, Mode=TwoWay}">
                                                    <ComboBoxItem Content="Tất cả" Tag="All"/>
                                                    <ComboBoxItem Content="Regular" Tag="Regular"/>
                                                    <ComboBoxItem Content="Silver" Tag="Silver"/>
                                                    <ComboBoxItem Content="Gold" Tag="Gold"/>
                                                    <ComboBoxItem Content="Platinum" Tag="Platinum"/>
                                                </ComboBox>
                                            </StackPanel>
                                            
                                            <!-- Points Filter -->
                                            <StackPanel Grid.Column="1" Margin="0,0,8,0">
                                                <TextBlock Text="Điểm Tích Lũy" FontSize="11" Foreground="#666" Margin="0,0,0,3"/>
                                                <ComboBox Height="32" x:Name="FilterPointsComboBox" SelectedValuePath="Tag" SelectedValue="{Binding SelectedFilterPoints, Mode=TwoWay}">
                                                    <ComboBoxItem Content="Tất cả" Tag="All"/>
                                                    <ComboBoxItem Content="&lt; 100 điểm" Tag="Under100"/>
                                                    <ComboBoxItem Content="100 - 500 điểm" Tag="100To500"/>
                                                    <ComboBoxItem Content="500 - 1000 điểm" Tag="500To1000"/>
                                                    <ComboBoxItem Content="&gt; 1000 điểm" Tag="Over1000"/>
                                                </ComboBox>
                                            </StackPanel>
                                            
                                            <!-- Activity Filter -->
                                            <StackPanel Grid.Column="2" Margin="0,0,8,0">
                                                <TextBlock Text="Trạng Thái" FontSize="11" Foreground="#666" Margin="0,0,0,3"/>
                                                <ComboBox Height="32" x:Name="FilterActivityComboBox" SelectedValuePath="Tag" SelectedValue="{Binding SelectedFilterActivity, Mode=TwoWay}">
                                                    <ComboBoxItem Content="Tất cả" Tag="All"/>
                                                    <ComboBoxItem Content="Có giao dịch" Tag="HasPurchases"/>
                                                    <ComboBoxItem Content="Chưa mua hàng" Tag="NoPurchases"/>
                                                </ComboBox>
                                            </StackPanel>
                                            
                                            <!-- Reset Button -->
                                            <Button Grid.Column="3" Content="🔄 Reset" Height="32" Width="80"
                                                    Background="#9E9E9E" Foreground="White" Command="{Binding ResetFiltersCommand}"
                                                    VerticalAlignment="Bottom" FontSize="12" Padding="8,4"/>
                                        </Grid>
                                    </Grid>
                                </Border>
                                
                                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                                    <TextBox Width="250" Margin="0,0,10,0" VerticalContentAlignment="Center" FontSize="14"
                                             Text="{Binding SearchTerm, UpdateSourceTrigger=PropertyChanged}"/>
                                    <TextBlock Text="🔍 Tìm" Padding="25,5" Background="#FF9800" Foreground="White" />
                                </StackPanel>
                            </Grid>
                            
                            <!-- Customer DataGrid with Pagination -->
                            <Grid Grid.Row="1">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                
                                <DataGrid x:Name="CustomerDataGrid" 
                                          Grid.Row="0"
                                          ItemsSource="{Binding PagedCustomers}"
                                          SelectedItem="{Binding SelectedCustomer, Mode=TwoWay}"
                                          AutoGenerateColumns="False" 
                                          IsReadOnly="True"
                                          SelectionMode="Single"
                                          Sorting="CustomerDataGrid_Sorting"
                                          GridLinesVisibility="Horizontal"
                                          AlternatingRowBackground="#F8F9FA"
                                          RowHeight="35"
                                          HorizontalAlignment="Stretch"
                                          VerticalAlignment="Stretch"
                                          ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                                          CanUserResizeColumns="True">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="ID" Binding="{Binding Id}" SortMemberPath="Id" Width="60">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                                    <Setter Property="FontWeight" Value="Bold"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="👤 Tên Khách Hàng" Binding="{Binding Name}" SortMemberPath="Name" Width="180"/>
                                        <DataGridTextColumn Header="📞 Điện Thoại" Binding="{Binding Phone}" SortMemberPath="Phone" Width="120"/>
                                        <DataGridTextColumn Header="📧 Email" Binding="{Binding Email}" SortMemberPath="Email" Width="200"/>
                                        <DataGridTextColumn Header="🏆 Hạng" Binding="{Binding Tier}" SortMemberPath="Tier" Width="100">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="⭐ Điểm" Binding="{Binding Points}" SortMemberPath="Points" Width="80">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                                    <Setter Property="FontWeight" Value="Bold"/>
                                                    <Setter Property="Foreground" Value="#FF9800"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="🏠 Địa Chỉ" Binding="{Binding Address}" SortMemberPath="Address" Width="250"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                                
                                <!-- Customer Pagination Controls -->
                                <Border Grid.Row="1" Background="#F8F9FA" Padding="15" Margin="0,10,0,0" CornerRadius="8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <!-- Page Info -->
                                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding PageInfoText}" FontWeight="Bold" Foreground="#1CB5E0"/>
                                            <TextBlock Text=" • " Margin="10,0"/>
                                            <TextBlock Text="👥 Tổng:" FontWeight="SemiBold" Margin="0,0,5,0"/>
                                            <TextBlock Text="{Binding TotalCustomersText}" FontWeight="Bold" Foreground="#FF9800"/>
                                        </StackPanel>
                                        
                                        <!-- Page Navigation -->
                                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                            <Button Content="⏮️" Width="35" Height="30" Background="#2196F3" Foreground="White" FontWeight="Bold" Command="{Binding FirstPageCommand}" Margin="0,0,5,0"/>
                                            <Button Content="◀️" Width="35" Height="30" Background="#2196F3" Foreground="White" FontWeight="Bold" Command="{Binding PrevPageCommand}" Margin="0,0,5,0"/>
                                            <TextBox Text="{Binding CurrentPageBox, UpdateSourceTrigger=PropertyChanged}" Width="50" Height="30" TextAlignment="Center" VerticalContentAlignment="Center" FontWeight="Bold" Margin="0,0,5,0">
                                                <TextBox.InputBindings>
                                                    <KeyBinding Key="Return" Command="{Binding GoToPageCommand}"/>
                                                </TextBox.InputBindings>
                                            </TextBox>
                                            <Button Content="▶️" Width="35" Height="30" Background="#2196F3" Foreground="White" FontWeight="Bold" Command="{Binding NextPageCommand}" Margin="0,0,5,0"/>
                                            <Button Content="⏭️" Width="35" Height="30" Background="#2196F3" Foreground="White" FontWeight="Bold" Command="{Binding LastPageCommand}"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Grid>
                    </TabItem>
                    
                    <!-- Purchase History Tab -->
                    <TabItem Header="🛒 Lịch Sử Mua Hàng">
                        <Grid Margin="10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            
                            <TextBlock Grid.Row="0" Text="📊 Lịch Sử Giao Dịch" FontSize="16" FontWeight="Bold" Foreground="#1CB5E0" Margin="0,0,0,15"/>
                            
                            <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" MinHeight="300">
                                <DataGrid ItemsSource="{Binding PurchaseHistory}"
                                          AutoGenerateColumns="False"
                                          IsReadOnly="True"
                                          GridLinesVisibility="Horizontal"
                                          AlternatingRowBackground="#F8F9FA"
                                          RowHeight="35"
                                          HorizontalAlignment="Stretch"
                                          VerticalAlignment="Stretch"
                                          MinHeight="300"
                                          CanUserResizeColumns="True">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="🧾 Mã HĐ" Binding="{Binding InvoiceId}" Width="100">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                                <Setter Property="FontWeight" Value="Bold"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="📅 Ngày Mua" Binding="{Binding CreatedAt}" Width="180"/>
                                    <DataGridTextColumn Header="📦 Số Mặt Hàng" Binding="{Binding ItemCount}" Width="120">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="💰 Tổng Tiền" Binding="{Binding Total}" Width="150">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                                <Setter Property="FontWeight" Value="Bold"/>
                                                <Setter Property="Foreground" Value="#4CAF50"/>
                                            </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                            </DataGrid.Columns>
                                </DataGrid>
                            </ScrollViewer>
                        </Grid>
                    </TabItem>
                </TabControl>
            </Border>
        </Grid>
    </Grid>
</Window>
