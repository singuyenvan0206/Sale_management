<Window x:Class="WpfApp1.VoucherManagementWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:WpfApp1"
        Title="Quản Lý Voucher" Height="650" Width="1000"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#555"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
        <local:BooleanToStatusColorConverter x:Key="BooleanToStatusColorConverter"/>
        <local:BooleanToStatusTextConverter x:Key="BooleanToStatusTextConverter"/>
    </Window.Resources>
    
    <Grid Background="#F5F5F5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <Border Grid.Row="0" Background="#FC5C7D" Padding="20">
            <TextBlock Text="🎟️ Quản Lý Mã Giảm Giá" FontSize="24" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
        </Border>
        
        <!-- Content -->
        <Grid Grid.Row="1" Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="380"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Input Form -->
            <Border Grid.Column="0" CornerRadius="12" Padding="20" Background="White" BorderBrush="#E0E0E0" BorderThickness="1" Margin="0,0,20,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto" PreviewMouseWheel="ScrollViewer_PreviewMouseWheel">
                    <StackPanel>
                        <TextBlock Text="Mã Voucher *" FontWeight="Bold"/>
                        <TextBox x:Name="CodeTextBox" CharacterCasing="Upper"/>

                        <TextBlock Text="Loại Giảm Giá"/>
                        <ComboBox x:Name="DiscountTypeComboBox" Height="35" Margin="0,0,0,10" SelectedIndex="0">
                            <ComboBoxItem Content="VND - Theo số tiền"/>
                            <ComboBoxItem Content="% - Theo phần trăm"/>
                        </ComboBox>

                        <TextBlock Text="Giá Trị Giảm"/>
                        <TextBox x:Name="DiscountValueTextBox"/>

                        <TextBlock Text="Hóa Đơn Tối Thiểu"/>
                        <TextBox x:Name="MinInvoiceTextBox" Text="0"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,5,0">
                                <TextBlock Text="Ngày Bắt Đầu"/>
                                <DatePicker x:Name="StartDatePicker" Height="35" Margin="0,0,0,10"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="5,0,0,0">
                                <TextBlock Text="Ngày Kết Thúc"/>
                                <DatePicker x:Name="EndDatePicker" Height="35" Margin="0,0,0,10"/>
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="Giới Hạn Số Lượt Dùng (0 = Vô hạn)"/>
                        <TextBox x:Name="UsageLimitTextBox" Text="0"/>

                        <CheckBox x:Name="IsActiveCheckBox" Content="Kích hoạt" IsChecked="True" Margin="0,5,0,15" FontSize="14"/>

                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0" HorizontalAlignment="Center">
                            <Button Content="➕ Thêm" Width="80" Background="#4CAF50" Foreground="White" Click="AddButton_Click" Margin="0,0,10,0"/>
                            <Button Content="✏️ Sửa" Width="80" Background="#2196F3" Foreground="White" Click="UpdateButton_Click" Margin="0,0,10,0"/>
                            <Button Content="🗑️ Xóa" Width="80" Background="#F44336" Foreground="White" Click="DeleteButton_Click"/>
                        </StackPanel>
                        <Button Content="🧹 Xóa Form" Background="#9E9E9E" Foreground="White" Margin="0,10,0,0" Click="ClearButton_Click"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- List -->
            <Border Grid.Column="1" CornerRadius="12" Padding="20" Background="White" BorderBrush="#E0E0E0" BorderThickness="1">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Danh Sách Mã Giảm Giá" FontSize="18" FontWeight="Bold" Margin="0,0,0,10"/>
                    
                    <!-- Filter Panel -->
                    <Border DockPanel.Dock="Top" Background="#F8F9FA" Padding="12" Margin="0,0,0,10" CornerRadius="8">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            
                            <TextBlock Grid.Row="0" Text="🔍 Lọc theo:" FontWeight="SemiBold" Margin="0,0,0,8" Foreground="#555"/>
                            
                            <Grid Grid.Row="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                
                                <!-- Active Status Filter -->
                                <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                    <TextBlock Text="Trạng Thái" FontSize="11" Foreground="#666" Margin="0,0,0,3"/>
                                    <ComboBox x:Name="FilterActiveComboBox" 
                                              Height="32" 
                                              SelectedIndex="0"
                                              SelectionChanged="VoucherFilterChanged">
                                        <ComboBoxItem Content="Tất cả" Tag="All"/>
                                        <ComboBoxItem Content="Đang hoạt động" Tag="Active"/>
                                        <ComboBoxItem Content="Không hoạt động" Tag="Inactive"/>
                                    </ComboBox>
                                </StackPanel>
                                
                                <!-- Discount Type Filter -->
                                <StackPanel Grid.Column="1" Margin="0,0,8,0">
                                    <TextBlock Text="Loại Giảm Giá" FontSize="11" Foreground="#666" Margin="0,0,0,3"/>
                                    <ComboBox x:Name="FilterDiscountTypeComboBox" 
                                              Height="32" 
                                              SelectedIndex="0"
                                              SelectionChanged="VoucherFilterChanged">
                                        <ComboBoxItem Content="Tất cả" Tag="All"/>
                                        <ComboBoxItem Content="Giảm VNĐ" Tag="VND"/>
                                        <ComboBoxItem Content="Giảm %" Tag="Percent"/>
                                    </ComboBox>
                                </StackPanel>
                                
                                <!-- Validity Filter -->
                                <StackPanel Grid.Column="2" Margin="0,0,8,0">
                                    <TextBlock Text="Thời Hạn" FontSize="11" Foreground="#666" Margin="0,0,0,3"/>
                                    <ComboBox x:Name="FilterValidityComboBox" 
                                              Height="32" 
                                              SelectedIndex="0"
                                              SelectionChanged="VoucherFilterChanged">
                                        <ComboBoxItem Content="Tất cả" Tag="All"/>
                                        <ComboBoxItem Content="Còn hiệu lực" Tag="ValidNow"/>
                                        <ComboBoxItem Content="Hết hạn" Tag="Expired"/>
                                        <ComboBoxItem Content="Sắp diễn ra" Tag="Upcoming"/>
                                    </ComboBox>
                                </StackPanel>
                                
                                <!-- Usage Filter -->
                                <StackPanel Grid.Column="3" Margin="0,0,8,0">
                                    <TextBlock Text="Sử Dụng" FontSize="11" Foreground="#666" Margin="0,0,0,3"/>
                                    <ComboBox x:Name="FilterUsageComboBox" 
                                              Height="32" 
                                              SelectedIndex="0"
                                              SelectionChanged="VoucherFilterChanged">
                                        <ComboBoxItem Content="Tất cả" Tag="All"/>
                                        <ComboBoxItem Content="Còn lượt dùng" Tag="Available"/>
                                        <ComboBoxItem Content="Hết lượt dùng" Tag="FullyUsed"/>
                                    </ComboBox>
                                </StackPanel>
                                
                                <!-- Reset Button -->
                                <Button Grid.Column="4" 
                                        Content="🔄 Reset" 
                                        Height="32" 
                                        Width="80"
                                        Background="#9E9E9E" 
                                        Foreground="White"
                                        Click="ResetVoucherFiltersButton_Click"
                                        VerticalAlignment="Bottom"
                                        FontSize="12"
                                        Padding="8,4"/>
                            </Grid>
                        </Grid>
                    </Border>
                    
                    <!-- Voucher Pagination Controls -->
                    <Border DockPanel.Dock="Bottom" Background="#F8F9FA" Padding="15" Margin="0,10,0,0" CornerRadius="8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            
                            <!-- Page Info -->
                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="📄 Trang:" FontWeight="SemiBold" Margin="0,0,5,0"/>
                                <TextBlock x:Name="VoucherPageInfoTextBlock" Text="1 / 1" FontWeight="Bold" Foreground="#1CB5E0"/>
                                <TextBlock Text=" • " Margin="10,0"/>
                                <TextBlock Text="🎟️ Tổng:" FontWeight="SemiBold" Margin="0,0,5,0"/>
                                <TextBlock x:Name="TotalVouchersTextBlock" Text="0 mã" FontWeight="Bold" Foreground="#FF9800"/>
                            </StackPanel>
                            
                            <!-- Page Navigation -->
                            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                <Button x:Name="VoucherFirstPageButton" Content="⏮️" Width="35" Height="30" 
                                        Background="#2196F3" Foreground="White" FontWeight="Bold"
                                        Click="VoucherFirstPageButton_Click" Margin="0,0,5,0"/>
                                <Button x:Name="VoucherPrevPageButton" Content="◀️" Width="35" Height="30" 
                                        Background="#2196F3" Foreground="White" FontWeight="Bold"
                                        Click="VoucherPrevPageButton_Click" Margin="0,0,5,0"/>
                                <TextBox x:Name="VoucherCurrentPageTextBox" Width="50" Height="30" 
                                         TextAlignment="Center" VerticalContentAlignment="Center"
                                         FontWeight="Bold" Margin="0,0,5,0"
                                         KeyDown="VoucherCurrentPageTextBox_KeyDown"/>
                                <Button x:Name="VoucherNextPageButton" Content="▶️" Width="35" Height="30" 
                                        Background="#2196F3" Foreground="White" FontWeight="Bold"
                                        Click="VoucherNextPageButton_Click" Margin="0,0,5,0"/>
                                <Button x:Name="VoucherLastPageButton" Content="⏭️" Width="35" Height="30" 
                                        Background="#2196F3" Foreground="White" FontWeight="Bold"
                                        Click="VoucherLastPageButton_Click"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                    <ListBox x:Name="VouchersListBox" SelectionChanged="VouchersListBox_SelectionChanged" BorderBrush="#CCCCCC" BorderThickness="1">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{Binding Code}" FontWeight="Bold" FontSize="16" Foreground="#E91E63"/>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="Giảm: " Foreground="#666"/>
                                            <TextBlock Text="{Binding DiscountValue, StringFormat={}{0:N0}}" FontWeight="Bold"/>
                                            <TextBlock Text="{Binding DiscountType}" Margin="5,0,0,0"/>
                                            <TextBlock Text=" • Đơn tối thiểu: " Foreground="#666" Margin="10,0,0,0"/>
                                            <TextBlock Text="{Binding MinInvoiceAmount, StringFormat={}{0:N0}}"/>
                                        </StackPanel>
                                        <TextBlock DataContext="{Binding}" Foreground="#555" FontSize="12" Margin="0,2,0,0">
                                            <TextBlock.Text>
                                                <MultiBinding StringFormat="📅 {0:dd/MM/yyyy} ➡ {1:dd/MM/yyyy}">
                                                    <Binding Path="StartDate"/>
                                                    <Binding Path="EndDate"/>
                                                </MultiBinding>
                                            </TextBlock.Text>
                                        </TextBlock>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Right">
                                        <Border Background="{Binding IsActive, Converter={StaticResource BooleanToStatusColorConverter}}" CornerRadius="4" Padding="6,2">
                                            <TextBlock Text="{Binding IsActive, Converter={StaticResource BooleanToStatusTextConverter}}" Foreground="White" FontSize="11"/>
                                        </Border>
                                        <TextBlock Text="{Binding UsedCount, StringFormat='Đã dùng: {0}'}" 
                                                   FontSize="12" Foreground="#666" HorizontalAlignment="Right" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="10"/>
                                <Setter Property="Margin" Value="0,2"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#FCE4EC"/>
                                        <Setter Property="BorderBrush" Value="#FC5C7D"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
