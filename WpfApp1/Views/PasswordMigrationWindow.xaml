<Window x:Class="FashionStore.PasswordMigrationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Mã Hóa Mật Khẩu" Height="400" Width="600"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="🔐 Mã Hóa Mật Khẩu" 
                       FontSize="24" 
                       FontWeight="Bold" 
                       Foreground="#1976D2" 
                       Margin="0,0,0,10"/>
            <TextBlock Text="Script này sẽ mã hóa tất cả mật khẩu chưa được mã hóa trong database." 
                       FontSize="14" 
                       Foreground="#666" 
                       TextWrapping="Wrap"/>
        </StackPanel>

        <!-- Info Panel -->
        <Border Grid.Row="1" 
                Background="White" 
                BorderBrush="#E0E0E0" 
                BorderThickness="1" 
                CornerRadius="5" 
                Padding="20"
                Margin="0,0,0,20">
            <StackPanel>
                <TextBlock Text="📋 Thông tin:" 
                           FontWeight="Bold" 
                           FontSize="16" 
                           Margin="0,0,0,15"/>
                
                <TextBlock Text="• Script sẽ tìm tất cả tài khoản có mật khẩu chưa được mã hóa" 
                           FontSize="13" 
                           Margin="0,0,0,8"/>
                <TextBlock Text="• Mã hóa từng mật khẩu bằng SHA256 với salt" 
                           FontSize="13" 
                           Margin="0,0,0,8"/>
                <TextBlock Text="• Cập nhật mật khẩu đã mã hóa vào database" 
                           FontSize="13" 
                           Margin="0,0,0,8"/>
                <TextBlock Text="• Quá trình này chỉ chạy một lần và an toàn" 
                           FontSize="13" 
                           Margin="0,0,0,8"/>
                <TextBlock Text="• Mật khẩu đã được mã hóa sẽ không bị ảnh hưởng" 
                           FontSize="13" 
                           Foreground="#4CAF50"/>
            </StackPanel>
        </Border>

        <!-- Status -->
        <Border Grid.Row="2" 
                x:Name="StatusBorder"
                Background="#E3F2FD" 
                BorderBrush="#2196F3" 
                BorderThickness="1" 
                CornerRadius="5" 
                Padding="15"
                Margin="0,0,0,20"
                Visibility="Collapsed">
            <StackPanel>
                <TextBlock x:Name="StatusText" 
                           FontSize="14" 
                           Foreground="#1976D2"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <!-- Buttons -->
        <StackPanel Grid.Row="3" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Right">
            <Button Content="🚀 Chạy Migration" 
                    x:Name="RunMigrationButton"
                    Height="45" 
                    Width="150" 
                    Background="#4CAF50" 
                    Foreground="White" 
                    FontSize="14" 
                    FontWeight="Bold"
                    BorderThickness="0"
                    Cursor="Hand"
                    Click="RunMigrationButton_Click"
                    Margin="0,0,10,0"/>
            <Button Content="Đóng" 
                    Height="45" 
                    Width="100" 
                    Background="#757575" 
                    Foreground="White" 
                    FontSize="14"
                    BorderThickness="0"
                    Cursor="Hand"
                    Click="CloseButton_Click"/>
        </StackPanel>
    </Grid>
</Window>

