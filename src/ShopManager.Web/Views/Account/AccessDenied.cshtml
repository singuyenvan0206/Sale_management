@{
    ViewData["Title"] = "Truy cập bị từ chối";
    Layout = "_Layout";
}

<div class="glass animate-in" style="max-width: 600px; margin: 4rem auto; text-align: center; padding: 3rem;">
    <div style="font-size: 5rem; color: #ef4444; margin-bottom: 1.5rem;">
        <i class="fas fa-user-lock"></i>
    </div>
    <h1 class="gradient-text" style="font-size: 2rem; margin-bottom: 1rem;">Truy cập bị từ chối</h1>
    <p style="color: var(--text-muted); margin-bottom: 2rem; font-size: 1.1rem;">
        Xin lỗi, bạn không có quyền hạn để truy cập vào chức năng này. 
        Vui lòng liên hệ với Quản trị viên nếu bạn tin rằng đây là một sự nhầm lẫn.
    </p>
    <div style="display: flex; gap: 1rem; justify-content: center;">
        <a href="javascript:history.back()" class="btn-secondary" style="text-decoration: none; padding: 0.75rem 1.5rem;">
            <i class="fas fa-arrow-left"></i> Quay lại
        </a>
        <a asp-controller="Dashboard" asp-action="Index" class="btn-primary" style="text-decoration: none; padding: 0.75rem 1.5rem;">
            <i class="fas fa-home"></i> Về Dashboard
        </a>
    </div>
</div>
