{
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Error"
    },
    "FilePath": "logs/app.log"
  },
  "Database": {
    "AutoMigrate": false
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "#{DB_CONNECTION_STRING}#"
  },
  "BankConfig": {
    "Code": "#{BANK_CODE}#",
    "Account": "#{BANK_ACCOUNT}#",
    "Name": "#{BANK_NAME}#"
  }
}
