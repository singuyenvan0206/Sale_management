<Window x:Class="FashionStore.App.Views.InvoicePrintWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:FashionStore.App"
        Title="Xem Trước In Hóa Đơn" Height="860" Width="1080"
        WindowStartupLocation="CenterScreen"
        Background="#EEF2F7">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#0F172A" Padding="16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="XEM TRƯỚC HÓA ĐƠN" FontSize="18" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text=" - Kiểm tra trước khi in" FontSize="12" Foreground="#94A3B8" Margin="8,0,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="PrintButton" Content="In Hóa Đơn" Width="120" Height="36" Background="#22C55E" Foreground="White" FontWeight="SemiBold" Click="PrintButton_Click" Margin="0,0,8,0"/>
                    <Button x:Name="CloseButton" Content="Đóng" Width="100" Height="36" Background="#EF4444" Foreground="White" FontWeight="SemiBold" Click="CloseButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Border Background="White" Padding="50" Margin="20" CornerRadius="10" BorderBrush="#D9E1EC" BorderThickness="1">
                <Grid x:Name="InvoicePreviewRoot" Width="800" Background="White">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/> <!-- Header -->
                        <RowDefinition Height="Auto"/> <!-- Customer -->
                        <RowDefinition Height="*"/>    <!-- Items -->
                        <RowDefinition Height="Auto"/> <!-- Totals -->
                        <RowDefinition Height="Auto"/> <!-- Footer -->
                    </Grid.RowDefinitions>

                    <!-- Header Section -->
                    <Border Grid.Row="0" BorderBrush="#1E293B" BorderThickness="0,0,0,2" Padding="0,0,0,25" Margin="0,0,0,30">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <TextBlock x:Name="CompanyNameText" Text="FASHION STORE PRO" 
                                           FontSize="32" FontWeight="ExtraBold" Foreground="#0F172A"/>
                                <TextBlock x:Name="CompanySloganText" Text="THỜI TRANG CAO CẤP - PHONG CÁCH HIỆN ĐẠI" 
                                           FontSize="13" Foreground="#D4AF37" FontWeight="Bold" Margin="0,5,0,15"/>
                                
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                    <TextBlock Text="Address: " FontWeight="Bold" Foreground="#64748B" FontSize="11"/>
                                    <TextBlock x:Name="CompanyAddressText" Text="123 Fashion District, Level 5" FontSize="11" Foreground="#1E293B"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                    <TextBlock Text="Phone: " FontWeight="Bold" Foreground="#64748B" FontSize="11"/>
                                    <TextBlock x:Name="CompanyPhoneText" Text="(+84) 901-234-567" FontSize="11" Foreground="#1E293B"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Email: " FontWeight="Bold" Foreground="#64748B" FontSize="11"/>
                                    <TextBlock x:Name="CompanyEmailText" Text="contact@fashionstore.com" FontSize="11" Foreground="#1E293B"/>
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Top">
                                <TextBlock Text="INVOICE" FontSize="44" FontWeight="Black" Foreground="#1E293B" Opacity="0.08" Margin="0,-15,-5,-15"/>
                                <TextBlock Text="HÓA ĐƠN" FontSize="28" FontWeight="Bold" Foreground="#1E293B" HorizontalAlignment="Right"/>
                                
                                <Border Background="#1E293B" CornerRadius="4" Padding="12,8" Margin="0,15,0,0">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        
                                        <TextBlock Grid.Row="0" Text="NO:" Foreground="#94A3B8" FontSize="10" FontWeight="Bold" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Row="0" Grid.Column="1" x:Name="InvoiceNumberText" Text="#1024" Foreground="White" FontSize="16" FontWeight="ExtraBold" Margin="10,0,0,0"/>
                                        
                                        <TextBlock Grid.Row="1" Text="DATE:" Foreground="#94A3B8" FontSize="10" FontWeight="Bold" Margin="0,5,0,0" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Row="1" Grid.Column="1" x:Name="InvoiceDateText" Text="15/04/2024" Foreground="#D4AF37" FontSize="12" FontWeight="Bold" Margin="10,5,0,0"/>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Customer Section -->
                    <Grid Grid.Row="1" Margin="0,0,0,35">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.2*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="BILL TO / KHÁCH HÀNG" FontSize="11" FontWeight="Black" Foreground="#64748B" Margin="0,0,0,10"/>
                            <Border Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Padding="20">
                                <StackPanel>
                                    <TextBlock x:Name="CustomerNameText" Text="NGUYỄN VĂN A" FontSize="18" FontWeight="Bold" Foreground="#0F172A" Margin="0,0,0,8"/>
                                    <TextBlock x:Name="CustomerPhoneText" Text="090 123 4567" FontSize="13" Foreground="#475569" Margin="0,0,0,5"/>
                                    <TextBlock x:Name="CustomerAddressText" Text="Số 123, Đường Lê Lợi, Quận 1, TP. HCM" FontSize="12" Foreground="#64748B" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="25,0,0,0">
                            <TextBlock Text="ORDER INFO / THÔNG TIN" FontSize="11" FontWeight="Black" Foreground="#64748B" Margin="0,0,0,10"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Text="Time:" FontSize="12" Foreground="#64748B" Margin="0,0,10,8"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" x:Name="InvoiceTimeText" Text="14:35" FontSize="12" FontWeight="SemiBold" Foreground="#1E293B"/>

                                <TextBlock Grid.Row="1" Text="Staff:" FontSize="12" Foreground="#64748B" Margin="0,0,10,0"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" x:Name="EmployeeNameText" Text="Admin Manager" FontSize="12" FontWeight="SemiBold" Foreground="#1E293B"/>
                            </Grid>
                        </StackPanel>
                    </Grid>

                    <!-- Items Table -->
                    <Border Grid.Row="2" BorderBrush="#1E293B" BorderThickness="0,2,0,2" Margin="0,0,0,30">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Border Background="#1E293B" Padding="15,10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="40"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="140"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="#" Foreground="#94A3B8" FontWeight="Bold" FontSize="11"/>
                                    <TextBlock Grid.Column="1" Text="SẢN PHẨM" Foreground="White" FontWeight="Bold" FontSize="11"/>
                                    <TextBlock Grid.Column="2" Text="UNIT PRICE" Foreground="White" FontWeight="Bold" FontSize="11" HorizontalAlignment="Right"/>
                                    <TextBlock Grid.Column="3" Text="QTY" Foreground="White" FontWeight="Bold" FontSize="11" HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Column="4" Text="TOTAL" Foreground="#D4AF37" FontWeight="Bold" FontSize="11" HorizontalAlignment="Right"/>
                                </Grid>
                            </Border>

                            <DataGrid Grid.Row="1" x:Name="InvoiceItemsList" Background="Transparent" BorderThickness="0" 
                                      AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="None" 
                                      GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#F1F5F9" RowHeaderWidth="0">
                                <DataGrid.RowStyle>
                                    <Style TargetType="DataGridRow">
                                        <Setter Property="Height" Value="45"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="Foreground" Value="#1E293B"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#F8FAFC"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGrid.RowStyle>
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="#" Binding="{Binding RowNumber}" Width="40"/>
                                    <DataGridTemplateColumn Header="Product" Width="*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding ProductName}" VerticalAlignment="Center" FontWeight="Bold" FontSize="13"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Header="Price" Binding="{Binding UnitPrice, StringFormat=N0}" Width="120">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="TextAlignment" Value="Right"/>
                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="Qty" Binding="{Binding Quantity}" Width="80">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="TextAlignment" Value="Center"/>
                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="Total" Binding="{Binding LineTotal, StringFormat=N0}" Width="140">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="TextAlignment" Value="Right"/>
                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                                <Setter Property="FontWeight" Value="ExtraBold"/>
                                                <Setter Property="Foreground" Value="#0F172A"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>

                    <!-- Totals Section -->
                    <Grid Grid.Row="3" Margin="0,0,0,40">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="360"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" VerticalAlignment="Bottom">
                            <TextBlock Text="NOTES / GHI CHÚ" FontSize="11" FontWeight="Black" Foreground="#64748B" Margin="0,0,0,8"/>
                            <TextBlock Text="Hóa đơn có giá trị trong vòng 07 ngày để đổi trả sản phẩm còn nguyên tem mác. Cảm ơn quý khách đã tin tưởng!" 
                                       FontSize="11" Foreground="#94A3B8" FontStyle="Italic" TextWrapping="Wrap"/>
                        </StackPanel>

                        <Border Grid.Column="1" Background="#F8FAFC" CornerRadius="12" Padding="20,25" BorderBrush="#CBD5E1" BorderThickness="1.2">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Text="Subtotal / Tạm tính:" FontSize="12" Foreground="#64748B" Margin="0,0,0,10"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" x:Name="SubtotalText" Text="0" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Right" Margin="10,0,0,10"/>

                                <TextBlock Grid.Row="1" Text="Tax / Thuế (VAT):" FontSize="12" Foreground="#64748B" Margin="0,0,0,10"/>
                                <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="10,0,0,10">
                                    <TextBlock x:Name="TaxRateText" Text="0%" FontSize="10" Foreground="#94A3B8" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                    <TextBlock x:Name="SalesTaxText" Text="0" FontSize="12" FontWeight="SemiBold"/>
                                </StackPanel>

                                <TextBlock Grid.Row="2" Text="Discount / Giảm giá:" FontSize="12" Foreground="#EF4444" Margin="0,0,0,10"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" x:Name="OtherText" Text="0" FontSize="12" FontWeight="SemiBold" Foreground="#EF4444" HorizontalAlignment="Right" Margin="10,0,0,10"/>

                                <Border Grid.Row="3" Grid.ColumnSpan="2" Height="1" Background="#E2E8F0" Margin="0,5,0,15"/>

                                <TextBlock Grid.Row="4" Text="TOTAL / TỔNG" FontSize="15" FontWeight="ExtraBold" Foreground="#0F172A" VerticalAlignment="Center"/>
                                <TextBlock Grid.Row="4" Grid.Column="1" x:Name="TotalText" Text="0" FontSize="22" FontWeight="Black" Foreground="#0F172A" HorizontalAlignment="Right" Margin="10,0,0,0"/>

                                <TextBlock Grid.Row="5" Text="Paid / Đã thanh toán:" FontSize="11" Foreground="#64748B" Margin="0,20,0,0"/>
                                <TextBlock Grid.Row="5" Grid.Column="1" x:Name="PaidText" Text="0" FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Right" Margin="10,20,0,0"/>
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- Footer -->
                    <Grid Grid.Row="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <StackPanel Grid.Column="0" HorizontalAlignment="Left">
                            <TextBlock Text="AUTHORIZED SIGNATURE" FontSize="10" FontWeight="Black" Foreground="#94A3B8" Margin="0,0,0,50"/>
                            <Border BorderBrush="#E2E8F0" BorderThickness="0,1,0,0" Width="180">
                                <TextBlock Text="Admin Confirmation" FontSize="10" Foreground="#CBD5E1" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                            </Border>
                        </StackPanel>

                        <StackPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Bottom">
                            <TextBlock Text="THANK YOU FOR SHOPPING WITH US" FontSize="12" FontWeight="ExtraBold" Foreground="#D4AF37" HorizontalAlignment="Right"/>
                            <TextBlock Text="www.fashionstore-pro.com" FontSize="10" Foreground="#94A3B8" HorizontalAlignment="Right" Margin="0,5,0,0"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>
        </ScrollViewer>

        <!-- Status Bar -->
        <Border Grid.Row="2" Background="#F8FAFC" Padding="12" BorderBrush="#CBD5E1" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="●" FontSize="14" Margin="0,0,8,0" Foreground="#22C55E"/>
                    <TextBlock x:Name="StatusText" Text="Sẵn sàng in hóa đơn" FontSize="12" 
                               Foreground="#37474F" FontWeight="SemiBold"/>
                </StackPanel>
                
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="🖨️" FontSize="12" Margin="0,0,4,0"/>
                    <TextBlock Text="Nhấn Ctrl+P để in nhanh" FontSize="10" Foreground="#666666"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
