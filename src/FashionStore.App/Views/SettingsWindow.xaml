<Window x:Class="FashionStore.App.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:FashionStore.App"
        Title="Cài Đặt" Height="520" Width="760"
        WindowStartupLocation="CenterScreen">
    
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </Window.Resources>

    <Grid Background="#F5F5F5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#1CB5E0" Padding="16">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock Text="⚙️ " FontSize="22" Foreground="White" VerticalAlignment="Center"/>
                <TextBlock Text="Cài Đặt"
                           FontSize="22"
                           FontWeight="Bold"
                           Foreground="White"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Main Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24,24,24,5">
                <!-- Database Settings -->
                <Border Background="White" CornerRadius="14" Padding="24" Margin="0,0,0,16">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="Cấu Hình Cơ Sở Dữ Liệu"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="#1CB5E0"
                                   Margin="0,0,0,12"/>

                        <Grid Grid.Row="1" >
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="180"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Máy chủ MySQL:" VerticalAlignment="Center"/>
                            <TextBox Grid.Row="0" Grid.Column="1" Height="32" Text="{Binding Server, UpdateSourceTrigger=PropertyChanged}"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Cơ sở dữ liệu:" VerticalAlignment="Center" Margin="0,8,0,0"/>
                            <TextBox Grid.Row="1" Grid.Column="1" Height="32" Margin="0,8,0,0" Text="{Binding Database, UpdateSourceTrigger=PropertyChanged}"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Tên đăng nhập:" VerticalAlignment="Center" Margin="0,8,0,0"/>
                            <TextBox Grid.Row="2" Grid.Column="1" Height="32" Margin="0,8,0,0" Text="{Binding UserId, UpdateSourceTrigger=PropertyChanged}"/>

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Mật khẩu:" VerticalAlignment="Center" Margin="0,8,0,0"/>
                            <PasswordBox x:Name="PasswordBox" Grid.Row="3" Grid.Column="1" Height="32" Margin="0,8,0,0"/>

                            <StackPanel Grid.Row="4" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                                <Button Content="Kiểm Tra Kết Nối" Width="140" Height="34" Margin="0,0,8,0" Click="TestConnectionButton_Click"/>
                                <Button Content="Lưu" Width="100" Height="34" Background="#4CAF50" Foreground="White" Click="SaveSettingsButton_Click"/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>

                <!-- Tier Settings -->
                <Border Background="White" CornerRadius="14" Padding="24" Margin="0,0,0,16">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="Cài Đặt Hạng Thành Viên"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="#1CB5E0"
                                   Margin="0,0,0,12"/>

                        <StackPanel Grid.Row="1">
                            <TextBlock Text="Quản lý các hạng thành viên và phần trăm giảm giá tương ứng"
                                       FontSize="14"
                                       Foreground="#666"
                                       Margin="0,0,0,16"/>
                            
                            <Button Content="⚙️ Mở Cài Đặt Hạng Thành Viên"
                                    Width="250"
                                    Height="40"
                                    Background="#673AB7"
                                    Foreground="White"
                                    FontSize="14"
                                    FontWeight="SemiBold"
                                    Command="{Binding OpenTierSettingsCommand}"
                                    Visibility="{Binding IsTierSettingsVisible, Converter={StaticResource BooleanToVisibilityConverter}}"
                                    HorizontalAlignment="Left"/>
                        </StackPanel>
                    </Grid>
                </Border>



                <!-- QR Code Settings -->
                <Border Background="White" CornerRadius="14" Padding="24">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="Cài Đặt QR Code Thanh Toán"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="#1CB5E0"
                                   Margin="0,0,0,12"/>

                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="180"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- QR Code Toggle -->
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Bật QR Code:" VerticalAlignment="Center"/>
                            <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <ToggleButton x:Name="QRCodeToggleButton" Width="60" Height="30" 
                                              IsChecked="{Binding EnableQRCode, Mode=TwoWay}">
                                    <ToggleButton.Style>
                                        <Style TargetType="ToggleButton">
                                            <Setter Property="Background" Value="#E0E0E0"/>
                                            <Setter Property="BorderBrush" Value="#CCCCCC"/>
                                            <Setter Property="BorderThickness" Value="1"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="ToggleButton">
                                                        <Border Background="{TemplateBinding Background}" 
                                                                BorderBrush="{TemplateBinding BorderBrush}" 
                                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                                CornerRadius="15">
                                                            <Grid>
                                                                <Ellipse x:Name="ToggleThumb" 
                                                                         Width="24" Height="24" 
                                                                         Fill="White" 
                                                                         HorizontalAlignment="Left" 
                                                                         VerticalAlignment="Center" 
                                                                         Margin="3"/>
                                                                <TextBlock x:Name="ToggleText" 
                                                                           Text="TẮT" 
                                                                           HorizontalAlignment="Right" 
                                                                           VerticalAlignment="Center" 
                                                                           Margin="0,0,8,0" 
                                                                           FontSize="10" 
                                                                           FontWeight="Bold" 
                                                                           Foreground="White"/>
                                                            </Grid>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsChecked" Value="True">
                                                                <Setter TargetName="ToggleThumb" Property="HorizontalAlignment" Value="Right"/>
                                                                <Setter TargetName="ToggleThumb" Property="Margin" Value="0,0,3,0"/>
                                                                <Setter TargetName="ToggleText" Property="Text" Value="BẬT"/>
                                                                <Setter TargetName="ToggleText" Property="HorizontalAlignment" Value="Left"/>
                                                                <Setter TargetName="ToggleText" Property="Margin" Value="8,0,0,0"/>
                                                                <Setter Property="Background" Value="#4CAF50"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </ToggleButton.Style>
                                </ToggleButton>
                                <TextBlock Text="{Binding QRCodeStatusText}" 
                                           Margin="12,0,0,0" VerticalAlignment="Center" 
                                           FontSize="12" Foreground="#666666"/>
                            </StackPanel>

                            <!-- Bank Account -->
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Số tài khoản:" VerticalAlignment="Center" Margin="0,16,0,0"/>
                            <TextBox Grid.Row="1" Grid.Column="1" Height="32" Margin="0,16,0,0" Text="{Binding BankAccount, UpdateSourceTrigger=PropertyChanged}"/>

                            <!-- Bank Code -->
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Mã ngân hàng:" VerticalAlignment="Center" Margin="0,8,0,0"/>
                            <TextBox Grid.Row="2" Grid.Column="1" Height="32" Margin="0,8,0,0" Text="{Binding BankCode, UpdateSourceTrigger=PropertyChanged}" ToolTip="Nhập mã ngân hàng (VD: TPB, VCB, BIDV...)"/>

                            <!-- Account Holder -->
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Tên chủ tài khoản:" VerticalAlignment="Center" Margin="0,8,0,0"/>
                            <TextBox Grid.Row="3" Grid.Column="1" Height="32" Margin="0,8,0,0" Text="{Binding AccountHolder, UpdateSourceTrigger=PropertyChanged}" ToolTip="Nhập tên chủ tài khoản"/>

                            <StackPanel Grid.Row="4" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                                <Button Content="Lưu thông tin ngân hàng" Width="180" Height="34" Background="#9C27B0" Foreground="White" Command="{Binding SavePaymentSettingsCommand}"/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <TextBlock Text="{Binding StatusText}" Grid.Row="2" Foreground="#666" HorizontalAlignment="Center" Margin="0,0,0,12"/>
        
        <!-- Reset Data Section -->
    </Grid>
</Window>
