<Window x:Class="FashionStore.App.Views.SplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Fashion Store Pro" Height="300" Width="500"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True">
    <Border CornerRadius="20" Background="#0F172A" BorderBrush="#D4AF37" BorderThickness="2">
        <Grid>
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <Image Source="/Assets/logo.png" Width="300" Height="150" Margin="0,0,0,20"/>
                
                <TextBlock Text="Fashion Store Pro Edition" 
                           Foreground="#D4AF37" 
                           FontSize="24" 
                           FontWeight="Bold" 
                           HorizontalAlignment="Center"
                           Margin="0,0,0,5"/>
                
                <TextBlock Text="Đang khởi động hệ thống..." 
                           Foreground="#94A3B8" 
                           FontSize="14" 
                           HorizontalAlignment="Center"
                           Margin="0,0,0,20"/>

                <ProgressBar x:Name="StartupProgress" 
                             Width="350" 
                             Height="8" 
                             IsIndeterminate="True"
                             Foreground="#D4AF37" 
                             Background="#1E293B"
                             BorderThickness="0"/>
            </StackPanel>
            
            <TextBlock Text="© 2026 SimSIMI Soft. All Rights Reserved." 
                       Foreground="#475569" 
                       FontSize="10" 
                       VerticalAlignment="Bottom" 
                       HorizontalAlignment="Center" 
                       Margin="0,0,0,10"/>
        </Grid>
    </Border>
</Window>
