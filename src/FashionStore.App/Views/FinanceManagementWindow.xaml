<Window x:Class="FashionStore.App.Views.FinanceManagementWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:FashionStore.App.ViewModels"
        Title="Chi Phí &amp; Tài Chính" Height="700" Width="1050"
        WindowStartupLocation="CenterScreen">
    <Window.DataContext>
        <vm:FinanceViewModel/>
    </Window.DataContext>
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8"
                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </Window.Resources>
    <Grid Background="#F5F5F5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#1CB5E0" Padding="20">
            <Grid>
                <TextBlock Text="💰 Chi Phí &amp; Tài Chính" FontSize="24" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                <StackPanel HorizontalAlignment="Right" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Tổng chi phí: " Foreground="#B3E5FF" FontSize="14" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding TotalExpensesText}" Foreground="White" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="360"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Input Form -->
            <Border Grid.Column="0" Background="White" CornerRadius="12" Padding="20" BorderBrush="#E0E0E0" BorderThickness="1" Margin="0,0,20,0">
                <StackPanel>
                    <TextBlock Text="Ghi Nhận Chi Phí Mới" FontSize="16" FontWeight="Bold" Foreground="#1E293B" Margin="0,0,0,20"/>

                    <TextBlock Text="Danh mục *" Foreground="#64748B" Margin="0,0,0,4"/>
                    <ComboBox ItemsSource="{Binding Categories}" Text="{Binding Category, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              IsEditable="True" Padding="8,6" FontSize="14" Margin="0,0,0,12" BorderBrush="#E0E0E0"/>

                    <TextBlock Text="Số tiền (đ) *" Foreground="#64748B" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding Amount, UpdateSourceTrigger=PropertyChanged}" 
                             Padding="8,6" Margin="0,0,0,12" BorderBrush="#E0E0E0" BorderThickness="1" FontSize="14"/>

                    <TextBlock Text="Mô tả" Foreground="#64748B" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}" 
                             Padding="8,6" Margin="0,0,0,20" BorderBrush="#E0E0E0" BorderThickness="1" FontSize="14"
                             TextWrapping="Wrap" Height="80"/>

                    <Button Content="➕ Thêm chi phí" Background="#10B981" Foreground="White" 
                            Command="{Binding AddExpenseCommand}" Height="42" Margin="0,0,0,8"/>
                    <Button Content="🗑️ Xóa" Background="#EF4444" Foreground="White" 
                            Command="{Binding DeleteExpenseCommand}" Height="42" Margin="0,0,0,8"/>
                    <Button Content="🧹 Xóa form" Background="#9E9E9E" Foreground="White" 
                            Command="{Binding ClearCommand}" Height="42"/>
                </StackPanel>
            </Border>

            <!-- Expense List -->
            <Border Grid.Column="1" Background="White" CornerRadius="12" Padding="20" BorderBrush="#E0E0E0" BorderThickness="1">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,16">
                        <TextBlock Text="📋 Danh Sách Chi Phí" FontSize="18" FontWeight="Bold" Foreground="#1E293B"/>
                        <Button Content="🔄" Background="Transparent" Foreground="#64748B" Padding="8,4"
                                Command="{Binding RefreshCommand}" Margin="8,0,0,0" FontSize="18"/>
                    </StackPanel>
                    <DataGrid ItemsSource="{Binding Expenses}" SelectedItem="{Binding SelectedExpense, Mode=TwoWay}"
                              IsReadOnly="True" AutoGenerateColumns="False" HeadersVisibility="Column"
                              GridLinesVisibility="None" BorderThickness="0" RowHeaderWidth="0"
                              CanUserAddRows="False" AlternatingRowBackground="#F8FAFC" SelectionMode="Single">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Ngày" Binding="{Binding CreatedDate, StringFormat={}{0:dd/MM/yy}}" Width="80"/>
                            <DataGridTextColumn Header="Danh mục" Binding="{Binding Category}" Width="160"/>
                            <DataGridTextColumn Header="Số tiền" Binding="{Binding Amount, StringFormat={}{0:C0}}" Width="130"/>
                            <DataGridTextColumn Header="Nhân viên" Binding="{Binding EmployeeName}" Width="120"/>
                            <DataGridTextColumn Header="Mô tả" Binding="{Binding Description}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
