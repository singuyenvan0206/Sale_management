<Window x:Class="FashionStore.App.Views.InventoryHubWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:FashionStore.App.ViewModels"
        Title="Trung Tâm Quản Lý Kho" Height="750" Width="1200"
        WindowStartupLocation="CenterScreen">
    <Window.DataContext>
        <vm:InventoryHubViewModel/>
    </Window.DataContext>
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8"
                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="Padding" Value="12,7"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </Window.Resources>
    <Grid Background="#F5F5F5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#1CB5E0" Padding="20">
            <TextBlock Text="📦 Trung Tâm Quản Lý Kho" FontSize="24" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
        </Border>

        <!-- Tab Control -->
        <TabControl Grid.Row="1" SelectedIndex="{Binding SelectedTab}" Background="#F5F5F5" BorderThickness="0">
            <!-- Tab 1: Stock Movements -->
            <TabItem Header="📋 Biến Động Kho" FontSize="14" FontWeight="SemiBold">
                <Border Background="White" Margin="16" CornerRadius="12" Padding="20" BorderBrush="#E0E0E0" BorderThickness="1">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,16">
                            <TextBlock Text="Lịch sử biến động tồn kho" FontSize="16" FontWeight="Bold" Foreground="#1E293B"/>
                            <Button Content="🔄 Làm mới" Background="#E2E8F0" Foreground="#475569"
                                    Command="{Binding RefreshCommand}" Margin="12,0,0,0" Padding="10,5"/>
                        </StackPanel>
                        <DataGrid ItemsSource="{Binding StockMovements}" IsReadOnly="True" AutoGenerateColumns="False"
                                  HeadersVisibility="Column" GridLinesVisibility="None" BorderThickness="0"
                                  RowHeaderWidth="0" CanUserAddRows="False" AlternatingRowBackground="#F8FAFC">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Thời gian" Binding="{Binding CreatedDate, StringFormat={}{0:dd/MM HH:mm}}" Width="110"/>
                                <DataGridTextColumn Header="Sản phẩm ID" Binding="{Binding ProductId}" Width="100"/>
                                <DataGridTextColumn Header="Loại" Binding="{Binding MovementType}" Width="100"/>
                                <DataGridTextColumn Header="Số lượng" Binding="{Binding Quantity}" Width="90"/>
                                <DataGridTextColumn Header="Trước" Binding="{Binding PreviousStock}" Width="80"/>
                                <DataGridTextColumn Header="Sau" Binding="{Binding NewStock}" Width="80"/>
                                <DataGridTextColumn Header="Ghi chú" Binding="{Binding Notes}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </Border>
            </TabItem>

            <!-- Tab 2: Purchase Orders -->
            <TabItem Header="🛒 Đơn Nhập Hàng" FontSize="14" FontWeight="SemiBold">
                <Grid Margin="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="380"/>
                    </Grid.ColumnDefinitions>

                    <!-- PO List -->
                    <Border Grid.Column="0" Background="White" CornerRadius="12" Padding="20" BorderBrush="#E0E0E0" BorderThickness="1" Margin="0,0,12,0">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top" Text="Danh Sách Đơn Nhập" FontSize="16" FontWeight="Bold" Foreground="#1E293B" Margin="0,0,0,16"/>
                            <ListBox ItemsSource="{Binding PurchaseOrders}" SelectedItem="{Binding SelectedPO, Mode=TwoWay}" BorderThickness="0">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="10" Margin="0,2" CornerRadius="8">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Id, StringFormat=#PO-{0:D5}}" FontWeight="Bold" Foreground="#1CB5E0" FontSize="14"/>
                                                    <TextBlock Text="{Binding SupplierName}" Foreground="#475569" FontSize="13"/>
                                                    <TextBlock Text="{Binding CreatedDate, StringFormat={}{0:dd/MM/yyyy}}" Foreground="#94A3B8" FontSize="11"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                                    <TextBlock Text="{Binding TotalAmount, StringFormat={}{0:C0}}" FontWeight="Bold" FontSize="14" HorizontalAlignment="Right"/>
                                                    <Border CornerRadius="12" Padding="6,2" HorizontalAlignment="Right">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Background" Value="#E0F2FE"/>
                                                            </Style>
                                                        </Border.Style>
                                                        <TextBlock Text="{Binding Status}" FontSize="11" FontWeight="Bold"/>
                                                    </Border>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </DockPanel>
                    </Border>

                    <!-- PO Details -->
                    <Border Grid.Column="1" Background="White" CornerRadius="12" Padding="20" BorderBrush="#E0E0E0" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="Chi Tiết Đơn Nhập" FontSize="16" FontWeight="Bold" Foreground="#1E293B" Margin="0,0,0,12"/>
                            <StackPanel x:Name="PODetailsPanel">
                                <TextBlock Text="{Binding SelectedPODetails.SupplierName, StringFormat='NCC: {0}'}" Foreground="#475569"/>
                                <TextBlock Text="{Binding SelectedPODetails.Status, StringFormat='Trạng thái: {0}'}" FontWeight="Bold" Foreground="#1CB5E0" Margin="0,4"/>
                                <TextBlock Text="{Binding SelectedPODetails.TotalAmount, StringFormat='Tổng: {0:C0}'}" FontWeight="Bold" FontSize="16" Foreground="#10B981" Margin="0,4,0,12"/>
                                <DataGrid ItemsSource="{Binding SelectedPODetails.Items}" IsReadOnly="True" AutoGenerateColumns="False"
                                          HeadersVisibility="Column" GridLinesVisibility="None" BorderThickness="1" BorderBrush="#E0E0E0"
                                          RowHeaderWidth="0" CanUserAddRows="False" MaxHeight="250">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Sản phẩm" Binding="{Binding ProductName}" Width="*"/>
                                        <DataGridTextColumn Header="SL" Binding="{Binding Quantity}" Width="50"/>
                                        <DataGridTextColumn Header="Đơn giá" Binding="{Binding UnitPrice, StringFormat={}{0:C0}}" Width="100"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                                <Button Content="✅ Xác nhận nhận hàng" Background="#10B981" Foreground="White" 
                                        Command="{Binding ReceivePOCommand}" Height="40" Margin="0,16,0,0"/>
                            </StackPanel>
                            <TextBlock Text="Chọn một đơn từ danh sách để xem chi tiết" Foreground="#94A3B8"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <!-- Tab 3: New PO -->
            <TabItem Header="➕ Tạo Đơn Nhập" FontSize="14" FontWeight="SemiBold">
                <Grid Margin="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="340"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- PO Info -->
                    <Border Grid.Column="0" Background="White" CornerRadius="12" Padding="20" BorderBrush="#E0E0E0" BorderThickness="1" Margin="0,0,12,0">
                        <StackPanel>
                            <TextBlock Text="Thông Tin Đơn Hàng" FontSize="16" FontWeight="Bold" Foreground="#1E293B" Margin="0,0,0,20"/>
                            <TextBlock Text="Nhà cung cấp *" Foreground="#64748B" Margin="0,0,0,4"/>
                            <ComboBox ItemsSource="{Binding Suppliers}" SelectedItem="{Binding SelectedSupplier, Mode=TwoWay}"
                                      DisplayMemberPath="Name" Padding="8,6" FontSize="14" Margin="0,0,0,16" BorderBrush="#E0E0E0"/>
                            <TextBlock Text="Ghi chú" Foreground="#64748B" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding PONotes, UpdateSourceTrigger=PropertyChanged}" 
                                     Padding="8,6" Margin="0,0,0,20" BorderBrush="#E0E0E0" BorderThickness="1" FontSize="14"
                                     TextWrapping="Wrap" Height="80"/>

                            <Border Background="#F0FDF4" CornerRadius="8" Padding="12" Margin="0,0,0,16">
                                <StackPanel>
                                    <TextBlock Text="Tổng tiền đơn:" Foreground="#15803D" FontSize="13"/>
                                    <TextBlock Text="{Binding TotalPOAmountText}" FontSize="22" FontWeight="Bold" Foreground="#10B981"/>
                                </StackPanel>
                            </Border>
                            <Button Content="📋 Tạo đơn nhập hàng" Background="#1CB5E0" Foreground="White" 
                                    Command="{Binding CreatePOCommand}" Height="42"/>
                        </StackPanel>
                    </Border>

                    <!-- Items List -->
                    <Border Grid.Column="1" Background="White" CornerRadius="12" Padding="20" BorderBrush="#E0E0E0" BorderThickness="1">
                        <DockPanel>
                            <!-- Add item row -->
                            <Border DockPanel.Dock="Top" Background="#F8FAFC" CornerRadius="8" Padding="12" Margin="0,0,0,12" BorderBrush="#E2E8F0" BorderThickness="1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="130"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Product Search with Popup Dropdown -->
                                    <Grid Grid.Column="0" Margin="0,0,8,0">
                                        <TextBox x:Name="ProductSearchBox"
                                                 Text="{Binding ProductSearchText, UpdateSourceTrigger=PropertyChanged}"
                                                 Padding="8,6" FontSize="13" BorderBrush="#E0E0E0" BorderThickness="1"
                                                 ToolTip="Gõ tên hoặc mã sản phẩm để tìm kiếm"/>
                                        <Popup IsOpen="{Binding IsDropdownOpen}" PlacementTarget="{Binding ElementName=ProductSearchBox}"
                                               Placement="Bottom" StaysOpen="False" AllowsTransparency="True" Width="350">
                                            <Border Background="White" BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="8"
                                                    Effect="{x:Null}" MaxHeight="220">
                                                <ListBox ItemsSource="{Binding FilteredProducts}"
                                                         BorderThickness="0" Background="Transparent"
                                                         MaxHeight="200">
                                                    <ListBox.ItemContainerStyle>
                                                        <Style TargetType="ListBoxItem">
                                                            <Setter Property="Padding" Value="10,8"/>
                                                            <Setter Property="Cursor" Value="Hand"/>
                                                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                                            <Style.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter Property="Background" Value="#EFF6FF"/>
                                                                </Trigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </ListBox.ItemContainerStyle>
                                                    <ListBox.ItemTemplate>
                                                        <DataTemplate>
                                                            <Button Background="Transparent" BorderThickness="0" Padding="0"
                                                                    Command="{Binding DataContext.SelectProductCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                    CommandParameter="{Binding}"
                                                                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Left">
                                                                <StackPanel>
                                                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="13" Foreground="#1E293B"/>
                                                                    <TextBlock FontSize="11" Foreground="#64748B">
                                                                        <TextBlock.Text>
                                                                            <MultiBinding StringFormat="Mã: {0}  |  Giá nhập: {1:C0}">
                                                                                <Binding Path="Code"/>
                                                                                <Binding Path="PurchasePrice"/>
                                                                            </MultiBinding>
                                                                        </TextBlock.Text>
                                                                    </TextBlock>
                                                                </StackPanel>
                                                            </Button>
                                                        </DataTemplate>
                                                    </ListBox.ItemTemplate>
                                                </ListBox>
                                            </Border>
                                        </Popup>
                                    </Grid>

                                    <TextBox Grid.Column="1" Text="{Binding NewItemQty, UpdateSourceTrigger=PropertyChanged}"
                                             Padding="6,5" Margin="0,0,8,0" BorderBrush="#E0E0E0" BorderThickness="1" FontSize="13"
                                             ToolTip="Số lượng"/>
                                    <TextBox Grid.Column="2" Text="{Binding NewItemPrice, UpdateSourceTrigger=PropertyChanged}"
                                             Padding="6,5" Margin="0,0,8,0" BorderBrush="#E0E0E0" BorderThickness="1" FontSize="13"
                                             ToolTip="Giá nhập (0 = dùng giá mặc định)"/>
                                    <Button Grid.Column="3" Content="➕ Thêm" Background="#10B981" Foreground="White"
                                            Command="{Binding AddItemCommand}" Padding="12,5"/>
                                </Grid>
                            </Border>

                            <TextBlock DockPanel.Dock="Top" Text="Danh Sách Mặt Hàng" FontSize="16" FontWeight="Bold" Foreground="#1E293B" Margin="0,0,0,12"/>
                            <DataGrid ItemsSource="{Binding NewPOItems}" AutoGenerateColumns="False"
                                      HeadersVisibility="Column" GridLinesVisibility="None" BorderThickness="1" BorderBrush="#E0E0E0"
                                      RowHeaderWidth="0" CanUserAddRows="False" IsReadOnly="True" AlternatingRowBackground="#F8FAFC">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Sản phẩm" Binding="{Binding ProductName}" Width="*"/>
                                    <DataGridTextColumn Header="Mã" Binding="{Binding ProductCode}" Width="90"/>
                                    <DataGridTextColumn Header="Số lượng" Binding="{Binding Quantity}" Width="80"/>
                                    <DataGridTextColumn Header="Đơn giá" Binding="{Binding UnitPrice, StringFormat={}{0:C0}}" Width="120"/>
                                    <DataGridTextColumn Header="Thành tiền" Binding="{Binding LineTotal, StringFormat={}{0:C0}}" Width="120"/>
                                    <DataGridTemplateColumn Header="Xóa" Width="60">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button Content="✕" Background="Transparent" Foreground="#EF4444" FontWeight="Bold"
                                                        Command="{Binding DataContext.RemoveItemCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding}" Padding="4,2"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </DockPanel>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
