<Window x:Class="FashionStore.App.Views.BarcodeScannerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Quét mã vạch Webcam" Height="500" Width="600"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">
    
    <Border Background="White" CornerRadius="15" BorderBrush="#1CB5E0" BorderThickness="2">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <!-- Header -->
            <Grid Grid.Row="0" Margin="0,0,0,15">
                <TextBlock Text="📷 QUÉT MÃ VẠCH / QR" FontSize="18" FontWeight="ExtraBold" Foreground="#1CB5E0" HorizontalAlignment="Center"/>
                <Button Content="✕" HorizontalAlignment="Right" Background="Transparent" BorderThickness="0" Foreground="#AAA" FontSize="16" Click="Cancel_Click" Cursor="Hand"/>
            </Grid>
            
            <!-- Camera Feed -->
            <Border Grid.Row="1" Background="#F5F5F5" CornerRadius="10" ClipToBounds="True">
                <Grid>
                    <Image x:Name="CameraImage" Stretch="UniformToFill"/>
                    
                    <!-- Scanning Overlay -->
                    <Border BorderBrush="#1CB5E0" BorderThickness="2" Width="300" Height="200" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="10" Color="#1CB5E0" Opacity="0.5" ShadowDepth="0"/>
                        </Border.Effect>
                    </Border>
                    
                    <!-- Scanner Animation Line -->
                    <Rectangle Fill="#1CB5E0" Height="2" Width="300" VerticalAlignment="Center">
                        <Rectangle.RenderTransform>
                            <TranslateTransform x:Name="ScannerLineTransform" Y="0"/>
                        </Rectangle.RenderTransform>
                    </Rectangle>
                </Grid>
            </Border>
            
            <!-- Controls -->
            <StackPanel Grid.Row="2" Margin="0,15,0,0">
                <TextBlock Text="Chọn Camera:" FontSize="12" FontWeight="Bold" Foreground="#777" Margin="0,0,0,5"/>
                <ComboBox x:Name="CameraComboBox" Height="36" DisplayMemberPath="Name" SelectionChanged="CameraComboBox_SelectionChanged"/>
            </StackPanel>
            
            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                <Button Content="HỦY BỎ" Width="120" Height="40" Background="#F44336" Foreground="White" FontWeight="Bold" BorderThickness="0" Click="Cancel_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="20"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>
        </Grid>
    </Border>

    <Window.Resources>
        <Storyboard x:Key="ScannerAnimation" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetName="ScannerLineTransform" 
                             Storyboard.TargetProperty="Y"
                             From="-100" To="100" Duration="0:0:1.5"
                             AutoReverse="True"/>
        </Storyboard>
    </Window.Resources>
</Window>
