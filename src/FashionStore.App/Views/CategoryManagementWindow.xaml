<Window x:Class="FashionStore.App.Views.CategoryManagementWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Quản Lý Danh Mục" Height="600" Width="700"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <Style TargetType="Button">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
    </Window.Resources>
    
    <Grid Background="#F5F5F5" PreviewMouseWheel="Grid_PreviewMouseWheel">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <Border Grid.Row="0" Background="#1CB5E0" Padding="20">
            <TextBlock Text="📂 Quản Lý Danh Mục" FontSize="24" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
        </Border>
        
        <!-- Content -->
        <Border Grid.Row="1" CornerRadius="12" Padding="20" Margin="20" Background="White" BorderBrush="#E0E0E0" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
                    <StackPanel Orientation="Horizontal" Margin="0,0,12,0" VerticalAlignment="Center">
                        <TextBlock Text="Tên DM:" Margin="0,0,6,0" VerticalAlignment="Center" FontWeight="SemiBold" />
                        <TextBox Width="150" Height="40" Text="{Binding EditingCategoryName, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,12,0" VerticalAlignment="Center">
                        <TextBlock Text="Thuế (%):" Margin="0,0,6,0" VerticalAlignment="Center" FontWeight="SemiBold" />
                        <TextBox Width="70"
                                 Height="40"
                                 Text="{Binding EditingCategoryTax, UpdateSourceTrigger=PropertyChanged}"
                                 TextAlignment="Center"
                                 IsReadOnly="True"
                                 IsEnabled="False"
                                 Background="#EFEFEF"
                                 ToolTip="Thuế danh mục được cố định trong hệ thống, không chỉnh sửa tại đây"/>
                    </StackPanel>
                    <Button Content="➕ Thêm" Width="90" Height="40" Background="#4CAF50" Foreground="White" Command="{Binding AddCommand}"/>
                    <Button Content="✏️ Cập Nhật" Width="100" Height="40" Background="#2196F3" Foreground="White" Margin="8,0,0,0" Command="{Binding UpdateCommand}"/>
                    <Button Content="🗑️ Xóa" Width="80" Height="40" Background="#F44336" Foreground="White" Margin="8,0,0,0" Command="{Binding DeleteCommand}"/>
                    <Button Content="⚠️ Xóa Hết" Width="95" Height="40" Background="#9E9E9E" Foreground="White" Margin="8,0,0,0" Command="{Binding DeleteAllCommand}"/>
                </StackPanel>
                
                <ListBox Grid.Row="1" ItemsSource="{Binding Categories}" SelectedItem="{Binding SelectedCategory, Mode=TwoWay}" 
                         BorderBrush="#CCCCCC" BorderThickness="1" Background="White">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                <TextBlock Text="  •  " Foreground="#B3E5FC" />
                                <TextBlock Text="Thuế: " Foreground="#555"/>
                                <TextBlock Text="{Binding TaxPercent, StringFormat={}{0:F2}%}" Foreground="#555"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="12,8"/>
                            <Setter Property="Margin" Value="0,2"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="#E0E0E0"
                                                BorderThickness="1"
                                                CornerRadius="8"
                                                Margin="0,2">
                                            <ContentPresenter Margin="{TemplateBinding Padding}"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="#E3F2FD"/>
                                                <Setter Property="BorderBrush" Value="#1CB5E0"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#F5F5F5"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>
                <TextBlock Text="{Binding StatusText}" FontSize="14" Foreground="#666" Margin="0,15,0,0" HorizontalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>
