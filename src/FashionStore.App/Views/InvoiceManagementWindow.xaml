<Window x:Class="FashionStore.App.Views.InvoiceManagementWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:oxy="http://oxyplot.org/wpf"
        xmlns:local="clr-namespace:FashionStore.App"
        xmlns:core="clr-namespace:FashionStore.App.Core"
        Title="Quản Lý Hóa Đơn" Height="800" Width="1280"
        WindowStartupLocation="CenterScreen">
    
    <Window.InputBindings>
        <KeyBinding Key="Enter" Command="{Binding AddItemCommand}"/>
        <KeyBinding Key="S" Modifiers="Control" Command="{Binding SaveInvoiceCommand}"/>
    </Window.InputBindings>
    
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <core:InverseBooleanConverter x:Key="InverseBooleanConverter"/>
    </Window.Resources>

	<Grid Background="#F5F5F5" PreviewMouseWheel="Grid_PreviewMouseWheel">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="*"/>
			<RowDefinition Height="Auto"/>
		</Grid.RowDefinitions>

		<!-- Header -->
		<Border Grid.Row="0" Effect="{StaticResource SubtleShadow}">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#1CB5E0" Offset="0"/>
                    <GradientStop Color="#000046" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid Margin="20,15">
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="*"/>
					<ColumnDefinition Width="Auto"/>
				</Grid.ColumnDefinitions>
				<StackPanel Orientation="Horizontal" VerticalAlignment="Center">
					<TextBlock Text="🧾" FontSize="28" VerticalAlignment="Center" Margin="0,0,10,0"/>
					<StackPanel>
                        <TextBlock Text="Fashion Store ERP" FontSize="12" Foreground="#B3E5FC" FontWeight="Bold"/>
                        <TextBlock Text="HỆ THỐNG BÁN HÀNG" FontSize="20" FontWeight="ExtraBold" Foreground="White"/>
                    </StackPanel>
                </StackPanel>
				<StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
					<TextBlock Text="👤 KHÁCH HÀNG:" Foreground="White" VerticalAlignment="Center" FontWeight="Bold" FontSize="11" Margin="0,0,10,0"/>
					<Grid Width="300" Height="36">
						<TextBox x:Name="CustomerSearchTextBox"
						         Height="36" FontSize="14" Padding="10,0" VerticalContentAlignment="Center"
						         Text="{Binding CustomerSearchText, UpdateSourceTrigger=PropertyChanged}"
						         ToolTip="Gõ tên / SĐT để tìm khách hàng"
                                 BorderThickness="0">
                            <TextBox.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="18"/>
                                </Style>
                            </TextBox.Resources>
                        </TextBox>
						<Popup x:Name="CustomerSuggestionsPopup"
						       PlacementTarget="{Binding ElementName=CustomerSearchTextBox}"
						       Placement="Bottom" StaysOpen="False" AllowsTransparency="True" PopupAnimation="Slide"
                               IsOpen="{Binding IsCustomerPopupOpen, Mode=TwoWay}">
							<Border Background="White" CornerRadius="8" Padding="2" Margin="0,5,0,0" Effect="{StaticResource CardShadow}">
								<ListBox x:Name="CustomerSuggestionsListBox"
								         Width="{Binding ElementName=CustomerSearchTextBox, Path=ActualWidth}"
								         MaxHeight="300" BorderThickness="0"
                                         ItemsSource="{Binding FilteredCustomers}"
                                         SelectedItem="{Binding SelectedCustomer, Mode=TwoWay}"
								         PreviewMouseWheel="ListBox_PreviewMouseWheel">
									<ListBox.ItemTemplate>
										<DataTemplate>
											<Border Padding="10,8" BorderBrush="#F5F5F5" BorderThickness="0,0,0,1">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="👤" Margin="0,0,8,0" Foreground="#1CB5E0"/>
                                                    <TextBlock Text="{Binding Name}" FontWeight="Bold" Foreground="#333"/>
                                                    <TextBlock Text=" - " Foreground="#999"/>
                                                    <TextBlock Text="{Binding Phone}" Foreground="#1CB5E0"/>
                                                </StackPanel>
                                            </Border>
										</DataTemplate>
									</ListBox.ItemTemplate>
								</ListBox>
							</Border>
						</Popup>
					</Grid>
					<Button Content="📜 Lịch sử" Width="110" Height="36" Margin="15,0,0,0" 
							Style="{StaticResource WarningButton}" Command="{Binding OpenHistoryCommand}"/>
					
                    <Border Background="White" Opacity="0.15" Width="1" Height="30" Margin="15,0"/>
                    
                    <Border Background="#20000000" CornerRadius="18" Padding="12,6" VerticalAlignment="Center">
						<StackPanel Orientation="Horizontal">
							<TextBlock Text="💎 " VerticalAlignment="Center"/>
							<TextBlock Text="{Binding LoyaltyTierText}" Foreground="White" FontWeight="Bold" FontSize="13"/>
							<TextBlock Text=" • " Foreground="#B3E5FC"/>
							<TextBlock Text="{Binding LoyaltyPointsText}" Foreground="#FFEB3B" FontWeight="Bold"/>
						</StackPanel>
					</Border>
				</StackPanel>
			</Grid>
		</Border>

		<!--Main Content -->
		<Grid Grid.Row="1" Margin="20">
			<Grid.RowDefinitions>
				<RowDefinition Height="Auto"/>
				<RowDefinition Height="*"/>
			</Grid.RowDefinitions>
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="*"/>
				<ColumnDefinition Width="380"/>
			</Grid.ColumnDefinitions>

			<!-- Product selector -->
			<Border Grid.Row="0" Background="White" CornerRadius="12" Padding="20" Margin="0,0,0,15" BorderBrush="#E0E0E0" BorderThickness="1" Effect="{StaticResource SubtleShadow}">
				<Grid>
					<Grid.RowDefinitions>
						<RowDefinition Height="Auto"/>
						<RowDefinition Height="Auto"/>
					</Grid.RowDefinitions>
					
					<!-- Barcode Scan Field -->
					<Border Grid.Row="0" Background="#F0F7F9" CornerRadius="10" Padding="15" Margin="0,0,0,15" BorderBrush="#1CB5E0" BorderThickness="1">
						<Grid>
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="Auto"/>
								<ColumnDefinition Width="*"/>
								<ColumnDefinition Width="Auto"/>
								<ColumnDefinition Width="Auto"/>
							</Grid.ColumnDefinitions>
							<StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,20,0">
                                <TextBlock Text="🚀" FontSize="20" Margin="0,0,10,0"/>
                                <TextBlock Text="QUÉT MÃ VẠCH NHANH:" FontWeight="ExtraBold" Foreground="#1CB5E0" VerticalAlignment="Center" FontSize="13"/>
                            </StackPanel>
							<TextBox x:Name="BarcodeTextBox" Grid.Column="1" Height="42" FontSize="18" FontWeight="Bold" Padding="15,6" 
									 Background="White" BorderBrush="#1CB5E0" BorderThickness="2"
									 Text="{Binding BarcodeText, UpdateSourceTrigger=PropertyChanged}"
									 ToolTip="Quét mã vạch hoặc nhập mã sản phẩm tại đây rồi nhấn Enter">
                                <TextBox.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="21"/>
                                    </Style>
                                </TextBox.Resources>
								<TextBox.InputBindings>
									<KeyBinding Key="Enter" Command="{Binding ScanBarcodeCommand}"/>
								</TextBox.InputBindings>
							</TextBox>
							
							<Button Grid.Column="2" Command="{Binding OpenWebcamScannerCommand}" 
									Width="50" Height="42" Margin="10,0,0,0"
									Style="{StaticResource ModernButton}" ToolTip="Quét bằng Webcam">
								<TextBlock Text="📷" FontSize="20"/>
							</Button>

							<TextBlock Grid.Column="3" Text="⚡ Hệ thống sẽ tự động thêm vào giỏ hàng" Margin="15,0,0,0" VerticalAlignment="Center" Foreground="#607D8B" FontStyle="Italic" FontSize="11"/>
						</Grid>
					</Border>

					<Grid Grid.Row="1">
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="*"/>
							<ColumnDefinition Width="100"/>
							<ColumnDefinition Width="130"/>
							<ColumnDefinition Width="Auto"/>
						</Grid.ColumnDefinitions>
						<StackPanel Grid.Column="0" Margin="0,0,15,0">
							<TextBlock Text="🔍 TÌM KIẾM THỦ CÔNG" FontWeight="Bold" Margin="5,0,0,6" Foreground="#555" FontSize="11"/>
							<ComboBox x:Name="ProductComboBox" Height="36" IsEditable="True" StaysOpenOnEdit="True"
									DisplayMemberPath="Name"
									ItemsSource="{Binding Products}"
									SelectedItem="{Binding SelectedProduct, Mode=TwoWay}"
									IsTextSearchEnabled="True" FontSize="14" Padding="10,6" ToolTip="Gõ để tìm sản phẩm theo tên hoặc mã"/>
						</StackPanel>
						<StackPanel Grid.Column="1" Margin="0,0,10,0" VerticalAlignment="Bottom">
							<TextBlock Text="📦 SỐ LƯỢNG" FontWeight="Bold" Margin="5,0,0,6" Foreground="#555" FontSize="11"/>
							<TextBox Height="36" Text="{Binding QuantityText, UpdateSourceTrigger=PropertyChanged}" FontSize="14" Padding="8,6" TextAlignment="Center" ToolTip="Số lượng"/>
						</StackPanel>
						<StackPanel Grid.Column="2" Margin="0,0,15,0" VerticalAlignment="Bottom">
							<TextBlock Text="💰 ĐƠN GIÁ" FontWeight="Bold" Margin="5,0,0,6" Foreground="#555" FontSize="11"/>
							<TextBox Height="36" FontSize="14" Padding="10,6" TextAlignment="Right" ToolTip="Đơn giá bán" Text="{Binding UnitPriceText, UpdateSourceTrigger=PropertyChanged}" Foreground="#2E7D32" FontWeight="Bold"/>
						</StackPanel>
						<Button Grid.Column="3" Content="✚ THÊM VÀO GIỎ" Width="200" Height="42" 
								Style="{StaticResource SuccessButton}" FontSize="14" 
								Command="{Binding AddItemCommand}" VerticalAlignment="Bottom"/>
					</Grid>
				</Grid>
			</Border>

			<!-- Items grid -->
			<Border Grid.Row="1" Background="White" CornerRadius="12" BorderBrush="#E0E0E0" BorderThickness="1">
				<Grid>
					<Grid.RowDefinitions>
						<RowDefinition Height="Auto"/>
						<RowDefinition Height="*"/>
					</Grid.RowDefinitions>
					
					<!-- Grid Header -->
					<Border Grid.Row="0" Background="#1CB5E0" CornerRadius="12,12,0,0" Padding="16,12">
						<Grid>
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="*"/>
								<ColumnDefinition Width="Auto"/>
							</Grid.ColumnDefinitions>
							<TextBlock Text="🛒 Danh sách sản phẩm" FontSize="16" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
							<StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
								<TextBlock Text="Tổng:" Foreground="White" FontWeight="SemiBold" Margin="0,0,5,0"/>
								<TextBlock Text="{Binding ItemCountText}" Foreground="White" FontWeight="Bold"/>
							</StackPanel>
						</Grid>
					</Border>
					
					<DataGrid Grid.Row="1"
					          x:Name="InvoiceItemsDataGrid"
					          AutoGenerateColumns="False"
					          CanUserAddRows="False"
					          SelectionMode="Single"
					          Background="White"
					          RowHeaderWidth="0"
					          EnableRowVirtualization="True"
					          EnableColumnVirtualization="False"
					          BorderThickness="0"
					          GridLinesVisibility="Horizontal"
					          HeadersVisibility="Column"
					          MinHeight="400"
                              ItemsSource="{Binding InvoiceItems}"
					          PreviewMouseWheel="ListBox_PreviewMouseWheel"
                              RowHeight="45"
                              AlternatingRowBackground="#FAFAFA">
				<DataGrid.Resources>
					<Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#F5F5F5"/>
                        <Setter Property="Foreground" Value="#555"/>
                        <Setter Property="Padding" Value="10,12"/>
                        <Setter Property="FontWeight" Value="ExtraBold"/>
                        <Setter Property="FontSize" Value="12"/>
                        <Setter Property="BorderThickness" Value="0,0,0,2"/>
                        <Setter Property="BorderBrush" Value="#1CB5E0"/>
                    </Style>
                    <Style TargetType="DataGridCell">
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Padding" Value="10,0"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="DataGridCell">
                                    <Border Background="{TemplateBinding Background}" BorderThickness="{TemplateBinding BorderThickness}" BorderBrush="{TemplateBinding BorderBrush}" SnapsToDevicePixels="True">
                                        <ContentPresenter VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
				</DataGrid.Resources>
				<DataGrid.Columns>
 					<DataGridTextColumn Header="#" Binding="{Binding RowNumber}" Width="40" IsReadOnly="True"/>
 					<DataGridTextColumn Header="SẢN PHẨM" Binding="{Binding ProductName}" Width="*" IsReadOnly="True">
                         <DataGridTextColumn.ElementStyle>
                             <Style TargetType="TextBlock">
                                 <Setter Property="FontWeight" Value="Bold"/>
                                 <Setter Property="VerticalAlignment" Value="Center"/>
                             </Style>
                         </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
 					<DataGridTextColumn Header="GIÁ BÁN" Binding="{Binding UnitPrice, StringFormat=N0}" Width="100" IsReadOnly="True">
 						<DataGridTextColumn.ElementStyle>
 							<Style TargetType="TextBlock">
 								<Setter Property="TextAlignment" Value="Right"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
 							</Style>
 						</DataGridTextColumn.ElementStyle>
 					</DataGridTextColumn>
 					<DataGridTextColumn Header="KM %" Binding="{Binding PromoDiscountPercent, StringFormat=N1}" Width="70" IsReadOnly="True">
 						<DataGridTextColumn.ElementStyle>
 							<Style TargetType="TextBlock">
 								<Setter Property="TextAlignment" Value="Right"/>
 								<Setter Property="FontWeight" Value="Bold"/>
 								<Setter Property="Foreground" Value="#E91E63"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
 							</Style>
 						</DataGridTextColumn.ElementStyle>
 					</DataGridTextColumn>
 					<DataGridTextColumn Header="SL" Binding="{Binding Quantity}" Width="60" IsReadOnly="True">
 						<DataGridTextColumn.ElementStyle>
 							<Style TargetType="TextBlock">
 								<Setter Property="TextAlignment" Value="Center"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
 							</Style>
 						</DataGridTextColumn.ElementStyle>
 					</DataGridTextColumn>
 					<DataGridTextColumn Header="THÀNH TIỀN" Binding="{Binding LineTotal, StringFormat=N0}" Width="120" IsReadOnly="True">
 						<DataGridTextColumn.ElementStyle>
 							<Style TargetType="TextBlock">
 								<Setter Property="TextAlignment" Value="Right"/>
                                <Setter Property="FontWeight" Value="ExtraBold"/>
                                <Setter Property="Foreground" Value="#1CB5E0"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
 							</Style>
 						</DataGridTextColumn.ElementStyle>
 					</DataGridTextColumn>
 					<DataGridTemplateColumn Header="⚙️" Width="130">
 						<DataGridTemplateColumn.CellTemplate>
 							<DataTemplate>
 								<StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
 									<Button Content="✚" Width="30" Height="30" Margin="0,0,5,0" 
 											Style="{StaticResource SuccessButton}" Padding="0"
                                            Command="{Binding DataContext.IncreaseQtyCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" CommandParameter="{Binding}"/>
 									<Button Content="➖" Width="30" Height="30" Margin="0,0,5,0" 
 											Style="{StaticResource WarningButton}" Padding="0"
                                            Command="{Binding DataContext.DecreaseQtyCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" CommandParameter="{Binding}"/>
 									<Button Content="🗑" Width="35" Height="30" 
 											Style="{StaticResource DangerButton}" Padding="0"
                                            Command="{Binding DataContext.RemoveItemCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" CommandParameter="{Binding}"/>
 								</StackPanel>
 							</DataTemplate>
 						</DataGridTemplateColumn.CellTemplate>
 					</DataGridTemplateColumn>
 				</DataGrid.Columns>
 			</DataGrid>
				</Grid>
			</Border>


			<!-- Right Summary Panel -->
			<Border Grid.Row="0" Grid.Column="1" Grid.RowSpan="3" Background="White" CornerRadius="15" Padding="25" Margin="15,0,0,0" BorderBrush="#E0E0E0" BorderThickness="1" Effect="{StaticResource CardShadow}">
				<Grid>
					<Grid.RowDefinitions>
						<RowDefinition Height="Auto"/>
						<RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
					</Grid.RowDefinitions>
					
					<!-- Summary Header -->
					<StackPanel Grid.Row="0" Margin="0,0,0,10">
						<TextBlock Text="THANH TOÁN" FontSize="18" FontWeight="ExtraBold" Foreground="#1CB5E0" HorizontalAlignment="Center"/>
                        <Border Background="#1CB5E0" Height="3" Width="50" HorizontalAlignment="Center" Margin="0,4,0,0"/>
					</StackPanel>
					
					<!-- Totals Content -->
					<StackPanel Grid.Row="1">
						<Grid Margin="0,0,0,8">
							<TextBlock Text="Tạm tính:" Foreground="#777" FontSize="13"/>
							<TextBlock Text="{Binding SubtotalText}" Foreground="#333" FontSize="15" FontWeight="Bold" HorizontalAlignment="Right"/>
						</Grid>

                        <Grid Margin="0,0,0,8">
							<TextBlock Text="Thuế GTGT:" Foreground="#777" FontSize="13"/>
							<TextBlock Text="{Binding TaxAmountText}" Foreground="#333" FontSize="13" FontWeight="Bold" HorizontalAlignment="Right"/>
						</Grid>

						<!-- Voucher Section -->
						<Border Background="#F8F9FA" CornerRadius="8" Padding="10,8" Margin="0,0,0,8">
                            <StackPanel>
                                <TextBlock Text="MÃ GIẢM GIÁ / VOUCHER" FontSize="9" FontWeight="Bold" Foreground="#999" Margin="0,0,0,6"/>
                                <Grid>
                                    <ComboBox x:Name="VoucherComboBox" Height="32" 
                                              DisplayMemberPath="Code" BorderThickness="1" BorderBrush="#DDD"
                                              ItemsSource="{Binding Vouchers}" SelectedItem="{Binding SelectedVoucher, Mode=TwoWay}"/>
                                </Grid>
                                <TextBlock Text="{Binding TierDiscountInlineText}" Foreground="#4CAF50" FontWeight="Bold" FontSize="10" Margin="0,5,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Manual Discount -->
						<Grid Margin="0,0,0,8">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Giảm trực tiếp:" Foreground="#777" FontSize="13" VerticalAlignment="Center"/>
                                <ComboBox x:Name="DiscountModeComboBox" Width="60" Height="28" Margin="8,0,0,0" ItemsSource="{Binding DiscountModes}" SelectedItem="{Binding SelectedDiscountMode, Mode=TwoWay}"/>
                            </StackPanel>
							<TextBox Width="90" Height="28" HorizontalAlignment="Right" TextAlignment="Right" Text="{Binding DiscountValueText, UpdateSourceTrigger=PropertyChanged}" FontWeight="Bold"/>
						</Grid>

                        <Border Background="#EEE" Height="1" Margin="0,5,0,10"/>

						<TextBlock Text="TỔNG TIỀN PHẢI TRẢ" HorizontalAlignment="Center" FontSize="11" FontWeight="Bold" Foreground="#D32F2F" Margin="0,0,0,2"/>
						<TextBlock Text="{Binding TotalText}" HorizontalAlignment="Center" FontWeight="ExtraBold" FontSize="32" Foreground="#D32F2F" Margin="0,0,0,10"/>

                        <!-- Payment info -->
						<Border Background="#F0FBF2" CornerRadius="8" Padding="12,8" Margin="0,0,0,8">
                            <StackPanel>
                                <Grid Margin="0,0,0,6">
                                    <TextBlock Text="PT Thanh toán:" VerticalAlignment="Center" FontWeight="Bold" FontSize="12"/>
                                    <ComboBox x:Name="PaymentMethodComboBox" Width="130" Height="28" HorizontalAlignment="Right" ItemsSource="{Binding PaymentMethods}" SelectedItem="{Binding SelectedPaymentMethod, Mode=TwoWay}"/>
                                </Grid>
                                <Grid>
                                    <TextBlock Text="Khách đã trả:" VerticalAlignment="Center" FontWeight="Bold" FontSize="12"/>
                                    <TextBox Width="130" Height="28" HorizontalAlignment="Right" TextAlignment="Right" FontSize="14" FontWeight="Bold" Text="{Binding PaidText, UpdateSourceTrigger=PropertyChanged}" BorderThickness="0" Background="Transparent" Foreground="#2E7D32"/>
                                </Grid>
                            </StackPanel>
                        </Border>

						<Grid Margin="10,0,10,8">
							<TextBlock Text="Tiền thối lại:" FontSize="13" Foreground="#777"/>
							<TextBlock Text="{Binding ChangeText}" FontSize="16" FontWeight="ExtraBold" Foreground="#388E3C" HorizontalAlignment="Right"/>
						</Grid>
					</StackPanel>

                    <!-- Save Buttons -->
                    <StackPanel Grid.Row="2" Margin="0,8,0,0">
                        <Button Content="THANH TOÁN" Height="52" 
                                Style="{StaticResource SuccessButton}" FontSize="18" FontWeight="ExtraBold"
                                Command="{Binding SaveInvoiceCommand}" Margin="0,0,0,8"/>
                        <Button Content="HỦY / LÀM MỚI" Height="36"
                                Style="{StaticResource DangerButton}" Opacity="0.8" FontSize="12"
                                Command="{Binding ClearInvoiceCommand}"/>
                    </StackPanel>
				</Grid>
			</Border>

		</Grid>
	</Grid>
</Window>
