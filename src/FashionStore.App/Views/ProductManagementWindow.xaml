<Window x:Class="FashionStore.App.Views.ProductManagementWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:FashionStore.App"
        Title="Quản Lý Sản Phẩm" Height="800" Width="1200"
        MinWidth="1200" MinHeight="800"
        WindowStartupLocation="CenterScreen">
    
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <Style TargetType="Button">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="0"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
    </Window.Resources>
    
    <Grid Background="#F5F5F5" PreviewMouseWheel="Grid_PreviewMouseWheel">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <Border Grid.Row="0" Background="#1CB5E0" Padding="20">
            <TextBlock Text="📦 Quản Lý Sản Phẩm" FontSize="24" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
        </Border>
        
        <Grid Grid.Row="1" Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="{Binding LeftPanelWidth}"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Input Form -->
            <Border Grid.Column="0" 
                    Visibility="{Binding IsSearchMode, Converter={StaticResource InverseBooleanToVisibilityConverter}}"
                    Background="White" CornerRadius="10" Padding="20" Margin="0,0,10,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            
                            <!-- Product Name -->
                            <StackPanel Grid.Row="0" Margin="0,0,0,12">
                                <TextBlock Text="Tên Sản Phẩm *" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                <TextBox Text="{Binding EditingProduct.Name, UpdateSourceTrigger=PropertyChanged}" Height="35"/>
                            </StackPanel>
                            
                            <!-- Product Code -->
                            <StackPanel Grid.Row="1" Margin="0,0,0,12">
                                <TextBlock Text="Mã Sản Phẩm" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                <TextBox Text="{Binding EditingProduct.Code, UpdateSourceTrigger=PropertyChanged}" Height="35" LostFocus="BarcodeTextBox_LostFocus">
                                    <TextBox.InputBindings>
                                        <KeyBinding Key="Enter" Command="{Binding LookupProductByCodeCommand}" />
                                    </TextBox.InputBindings>
                                </TextBox>
                            </StackPanel>
                            
                            <!-- Category and Supplier -->
                            <Grid Grid.Row="2" Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Danh Mục" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                    <ComboBox ItemsSource="{Binding Categories}" 
                                              SelectedValuePath="Id" 
                                              DisplayMemberPath="Name" 
                                              SelectedValue="{Binding EditingProduct.CategoryId}" 
                                              Height="35"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Nhà Cung Cấp" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                    <ComboBox ItemsSource="{Binding Suppliers}" 
                                              SelectedValuePath="Id" 
                                              DisplayMemberPath="Name" 
                                              SelectedValue="{Binding EditingProduct.SupplierId}" 
                                              Height="35"/>
                                </StackPanel>
                            </Grid>
                            
                            <!-- Prices -->
                            <Grid Grid.Row="3" Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Giá Bán *" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                    <TextBox Text="{Binding EditingProduct.SalePrice, UpdateSourceTrigger=PropertyChanged}" Height="35"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Giá Nhập" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                    <TextBox Text="{Binding EditingProduct.PurchasePrice, UpdateSourceTrigger=PropertyChanged}" Height="35"/>
                                </StackPanel>
                            </Grid>
                            
                            <!-- Quantity -->
                            <Grid Grid.Row="4" Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Số Lượng Nhập" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                    <TextBox Text="{Binding EditingProduct.ImportQuantity, UpdateSourceTrigger=PropertyChanged}" Height="35"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Còn Lại" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                    <TextBox Text="{Binding EditingProduct.StockQuantity, UpdateSourceTrigger=PropertyChanged}" Height="35"/>
                                </StackPanel>
                            </Grid>

                            <!-- Promotion -->
                            <Border Grid.Row="5" Background="#FFF9C4" Padding="10" CornerRadius="8" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="🎁 Khuyến Mãi" FontWeight="Bold" Foreground="#F57F17" Margin="0,0,0,5"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Giảm (%)" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                        <TextBox Grid.Column="1" Text="{Binding EditingProduct.PromoDiscountPercent, UpdateSourceTrigger=PropertyChanged}" Height="30"/>
                                    </Grid>
                                    <Grid Margin="0,5,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="5"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="Từ Ngày" FontSize="11"/>
                                            <DatePicker SelectedDate="{Binding EditingProduct.PromoStartDate}" Height="30"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="Đến Ngày" FontSize="11"/>
                                            <DatePicker SelectedDate="{Binding EditingProduct.PromoEndDate}" Height="30"/>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- Description -->
                            <StackPanel Grid.Row="6" Margin="0,0,0,20">
                                <TextBlock Text="Mô Tả Chi Tiết" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                <TextBox Text="{Binding EditingProduct.Description, UpdateSourceTrigger=PropertyChanged}"
                                         Height="80" 
                                         TextWrapping="Wrap" 
                                         AcceptsReturn="True"
                                         VerticalScrollBarVisibility="Auto"/>
                            </StackPanel>
                            
                            <!-- Actions -->
                            <Grid Grid.Row="7" Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0" Content="🌿 Thêm" Background="#4CAF50" Foreground="White" Command="{Binding AddCommand}"/>
                                <Button Grid.Column="2" Content="📝 Sửa" Background="#2196F3" Foreground="White" Command="{Binding UpdateCommand}"/>
                                <Button Grid.Column="4" Content="🗑️ Xóa" Background="#F44336" Foreground="White" Command="{Binding DeleteCommand}"/>
                            </Grid>
                            
                            <Button Grid.Row="8" Content="🧹 Làm Mới Form" Background="#9E9E9E" Foreground="White" Command="{Binding ClearCommand}" Margin="0,0,0,10"/>
                            
                            <Expander Header="Chức Năng Khác" Grid.Row="9" Foreground="#666">
                                <StackPanel Margin="5">
                                    <Button Content="📥 Nhập từ CSV" Background="#FF9800" Foreground="White" Command="{Binding ImportCsvCommand}" Margin="0,0,0,5"/>
                                    <Button Content="📤 Xuất sang CSV" Background="#FF9800" Foreground="White" Command="{Binding ExportCsvCommand}" Margin="0,0,0,5"/>
                                    <Button Content="⚠ Xóa Tất Cả" Background="#9E9E9E" Foreground="White" Command="{Binding DeleteAllCommand}"/>
                                </StackPanel>
                            </Expander>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- Product List Panel -->
            <Border Grid.Column="1" Background="White" CornerRadius="10" Padding="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,15">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                        <TextBlock Grid.Row="0" 
                                   Text="📦 Danh Sách Sản Phẩm" 
                                   FontSize="18" 
                                   FontWeight="Bold" 
                                   Foreground="#1CB5E0"
                                   Margin="0,0,0,10"/>
                        
                        <!-- Filter Panel -->
                        <Border Grid.Row="1" Background="#F8F9FA" Padding="12" Margin="0,0,0,10" CornerRadius="8">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                
                                <TextBlock Grid.Row="0" Text="🔍 Lọc theo:" FontWeight="SemiBold" Margin="0,0,0,8" Foreground="#555"/>
                                
                                <Grid Grid.Row="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                        <TextBlock Text="Danh Mục" FontSize="11" Foreground="#666" Margin="0,0,0,3"/>
                                        <ComboBox ItemsSource="{Binding FilterCategories}" SelectedValuePath="Id" DisplayMemberPath="Name" SelectedValue="{Binding SelectedFilterCategoryId}" Height="32"/>
                                    </StackPanel>
                                    
                                    <StackPanel Grid.Column="1" Margin="0,0,8,0">
                                        <TextBlock Text="Nhà Cung Cấp" FontSize="11" Foreground="#666" Margin="0,0,0,3"/>
                                        <ComboBox ItemsSource="{Binding FilterSuppliers}" SelectedValuePath="Id" DisplayMemberPath="Name" SelectedValue="{Binding SelectedFilterSupplierId}" Height="32"/>
                                    </StackPanel>
                                    
                                    <StackPanel Grid.Column="2" Margin="0,0,8,0">
                                        <TextBlock Text="Tồn Kho" FontSize="11" Foreground="#666" Margin="0,0,0,3"/>
                                        <ComboBox SelectedValuePath="Tag" SelectedValue="{Binding SelectedFilterStock}" Height="32">
                                            <ComboBoxItem Content="Tất cả" Tag="All"/>
                                            <ComboBoxItem Content="Hết hàng (0)" Tag="OutOfStock"/>
                                            <ComboBoxItem Content="Sắp hết (&lt;10)" Tag="LowStock"/>
                                            <ComboBoxItem Content="Còn hàng (≥10)" Tag="InStock"/>
                                        </ComboBox>
                                    </StackPanel>
                                    
                                    <StackPanel Grid.Column="3" Margin="0,0,8,0">
                                        <TextBlock Text="Khuyến Mãi" FontSize="11" Foreground="#666" Margin="0,0,0,3"/>
                                        <ComboBox SelectedValuePath="Tag" SelectedValue="{Binding SelectedFilterPromo}" Height="32">
                                            <ComboBoxItem Content="Tất cả" Tag="All"/>
                                            <ComboBoxItem Content="Có KM" Tag="HasPromo"/>
                                            <ComboBoxItem Content="Không KM" Tag="NoPromo"/>
                                        </ComboBox>
                                    </StackPanel>
                                    
                                    <StackPanel Grid.Column="4" Margin="0,0,8,0">
                                        <TextBlock Text="Khoảng Giá" FontSize="11" Foreground="#666" Margin="0,0,0,3"/>
                                        <ComboBox SelectedValuePath="Tag" SelectedValue="{Binding SelectedFilterPrice}" Height="32">
                                            <ComboBoxItem Content="Tất cả" Tag="All"/>
                                            <ComboBoxItem Content="&lt; 100k" Tag="Under100k"/>
                                            <ComboBoxItem Content="100k - 500k" Tag="100kTo500k"/>
                                            <ComboBoxItem Content="500k - 1M" Tag="500kTo1M"/>
                                            <ComboBoxItem Content="&gt; 1M" Tag="Over1M"/>
                                        </ComboBox>
                                    </StackPanel>
                                    
                                    <Button Grid.Column="5" Content="🔄 Reset" Command="{Binding ResetFiltersCommand}" Height="32" Width="80" Background="#9E9E9E" Foreground="White" VerticalAlignment="Bottom" FontSize="12" Padding="8,4"/>
                                </Grid>
                            </Grid>
                        </Border>
                        
                        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                            <TextBox Text="{Binding SearchTerm, UpdateSourceTrigger=PropertyChanged}" 
                                     Width="250" Height="32" Margin="0,0,10,0"
                                     VerticalContentAlignment="Center" FontSize="14" Padding="8,6"/>
                            <Button Content="🔍 Tìm Kiếm" Command="{Binding SearchCommand}" Width="100" Height="32" Background="#FF9800" Foreground="White" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Grid>

                    <Border Grid.Row="1" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="8">
                        <DataGrid x:Name="ProductDataGrid" 
                                  ItemsSource="{Binding PagedProducts}"
                                  SelectedItem="{Binding SelectedProduct, Mode=TwoWay}"
                                  AutoGenerateColumns="False" 
                                  IsReadOnly="True"
                                  SelectionMode="Single"
                                  Sorting="ProductDataGrid_Sorting"
                                  GridLinesVisibility="Horizontal"
                                  AlternatingRowBackground="#F8F9FA"
                                  RowHeight="35"
                                  HorizontalAlignment="Stretch"
                                  VerticalAlignment="Stretch"
                                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60" FontWeight="Bold"/>
                                <DataGridTextColumn Header="📦 Tên Sản Phẩm" Binding="{Binding Name}" Width="250"/>
                                <DataGridTextColumn Header="🏷️ Mã SP" Binding="{Binding Code}" Width="120" FontFamily="Consolas"/>
                                <DataGridTextColumn Header="📂 Danh Mục" Binding="{Binding CategoryName}" Width="120"/>
                                <DataGridTextColumn Header="💰 Giá Bán" Binding="{Binding SalePrice, StringFormat=N0}" Width="120" FontWeight="Bold" Foreground="#4CAF50"/>
                                <DataGridTextColumn Header="🏷️ Giá sau KM" Binding="{Binding FinalPrice, StringFormat=N0}" Width="120" FontWeight="Bold" Foreground="#E91E63"/>
                                <DataGridTextColumn Header="🔥 KM%" Binding="{Binding PromoDiscountPercent, StringFormat=N0}" Width="60" Foreground="#E91E63"/>
                                <DataGridTextColumn Header="📊 Tồn Kho" Binding="{Binding StockQuantity}" Width="80" FontWeight="Bold" Foreground="#FF9800"/>
                                <DataGridTextColumn Header="💰 Giá Nhập" Binding="{Binding PurchasePrice, StringFormat=N0}" Width="100"/>
                                <DataGridTextColumn Header="📦 SL Nhập" Binding="{Binding ImportQuantity}" Width="80"/>
                                <DataGridTextColumn Header="🏪 Nhà Cung Cấp" Binding="{Binding SupplierName}" Width="150"/>
                                <DataGridTextColumn Header="📝 Mô Tả" Binding="{Binding Description}" Width="200"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>

                    <Border Grid.Row="2" Background="#F8F9FA" Padding="15" Margin="0,10,0,0" CornerRadius="8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding PageInfoText}" FontWeight="SemiBold" Foreground="#1CB5E0" VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                <Button Content="⏮️" Width="35" Height="30" Background="#2196F3" Foreground="White" Command="{Binding FirstPageCommand}" Margin="0,0,5,0"/>
                                <Button Content="◀️" Width="35" Height="30" Background="#2196F3" Foreground="White" Command="{Binding PrevPageCommand}" Margin="0,0,5,0"/>
                                <TextBox Text="{Binding CurrentPageBox, UpdateSourceTrigger=PropertyChanged}" Width="50" Height="30" Margin="0,0,5,0" TextAlignment="Center" VerticalContentAlignment="Center">
                                    <TextBox.InputBindings>
                                        <KeyBinding Key="Return" Command="{Binding GoToPageCommand}" />
                                    </TextBox.InputBindings>
                                </TextBox>
                                <Button Content="▶️" Width="35" Height="30" Background="#2196F3" Foreground="White" Command="{Binding NextPageCommand}" Margin="0,0,5,0"/>
                                <Button Content="⏭️" Width="35" Height="30" Background="#2196F3" Foreground="White" Command="{Binding LastPageCommand}"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
