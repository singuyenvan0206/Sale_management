<Window x:Class="FashionStore.App.Views.DashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:oxy="http://oxyplot.org/wpf"
        xmlns:local="clr-namespace:FashionStore.App"
        Title="🏪 Hệ Thống Quản Lý POS" Height="700" Width="1200"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized">  
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </Window.Resources>
    
    <Grid Background="#F5F5F5">
        <!-- Header -->
        <Grid.RowDefinitions>
            <RowDefinition Height="80"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- Header Bar -->
        <Border Grid.Row="0" BorderBrush="#334155" BorderThickness="0,0,0,1" Padding="20">
            <Border.Background>
                <SolidColorBrush Color="#00AEEF"/>
            </Border.Background>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="🏪 Hệ Thống Quản Lý POS" 
                               FontSize="24" 
                               FontWeight="Bold" 
                               Foreground="White" 
                               VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding UserInfoText}" 
                               FontSize="16" 
                               Foreground="{StaticResource GoldBrush}" 
                               VerticalAlignment="Center"
                               Margin="20,0,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="LowStockAlertButton"
                            Click="LowStockAlertButton_Click"
                            Width="180" 
                            Height="40"
                            Margin="0,0,10,0"
                            Background="#FFC107"
                            Foreground="White"
                            FontWeight="Bold"
                            FontSize="12"
                            Padding="12,8"
                            Cursor="Hand"
                            Opacity="0.9">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="⚠️ Sắp hết" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <Border Background="#DC2626" 
                                    CornerRadius="12" 
                                    Padding="6,2"
                                    MinWidth="30">
                                <TextBlock Text="{Binding LowStockAlertCount}" 
                                          Foreground="White" 
                                          FontWeight="Bold" 
                                          FontSize="12"
                                          HorizontalAlignment="Center"/>
                            </Border>
                        </StackPanel>
                    </Button>
                    
                    <Button Content="🚪 Đăng Xuất" 
                            Width="120" 
                            Height="35" 
                            Background="#FC5C7D" 
                            Foreground="White" 
                            Command="{Binding LogoutCommand}"
                            CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"/>
                </StackPanel>
            </Grid>
        </Border>
        
        <!-- Main Content with left nav -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left Nav -->
            <Border Grid.Column="0" Background="#1E293B" BorderBrush="#334155" BorderThickness="0,0,1,0" CornerRadius="0,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <!-- Header -->
                    <Border Grid.Row="0" Background="#0F172A" CornerRadius="0,20,0,0" Padding="20,25,20,20">
                        <StackPanel>
                            <TextBlock Text="🎛️" FontSize="24" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                            <TextBlock Text="QUẢN LÝ" 
                                       Foreground="White" 
                                       FontWeight="Bold" 
                                       FontSize="18"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="Hệ thống POS" 
                                       Foreground="#94A3B8" 
                                       FontSize="12"
                                       HorizontalAlignment="Center"
                                       Margin="0,2,0,0"/>
                        </StackPanel>
                    </Border>
                    
                    <!-- Navigation Menu -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Hidden">
                        <StackPanel Margin="0,20,0,0">
                            <ListBox x:Name="NavList" 
                                     SelectionChanged="NavList_SelectionChanged"
                                     PreviewMouseWheel="NavList_PreviewMouseWheel"
                                     Background="Transparent" 
                                     BorderThickness="0" 
                                     Foreground="#CBD5E1">
                                <ListBox.Resources>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListBoxItem">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="6"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <!-- Left accent bar -->
                                                        <Border x:Name="Accent"
                                                                Grid.Column="0"
                                                                Background="Transparent"
                                                                CornerRadius="3"/>
                                                        <!-- Item background + content -->
                                                        <Border x:Name="ItemBorder"
                                                                Grid.Column="1"
                                                                Background="Transparent"
                                                                Margin="10,4,12,4"
                                                                CornerRadius="12"
                                                                Padding="14,10">
                                                            <ContentPresenter/>
                                                        </Border>
                                                    </Grid>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsSelected" Value="True">
                                                            <Setter TargetName="ItemBorder" Property="Background" Value="#00AEEF"/>
                                                            <Setter TargetName="Accent" Property="Background" Value="#00AEEF"/>
                                                            <Setter Property="Foreground" Value="White"/>
                                                        </Trigger>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="ItemBorder" Property="Background" Value="#334155"/>
                                                            <Setter TargetName="Accent" Property="Background" Value="#00AEEF"/>
                                                            <Setter Property="Foreground" Value="White"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Setter Property="FontSize" Value="15"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Setter Property="HorizontalContentAlignment" Value="Left"/>
                                    </Style>
                                </ListBox.Resources>
                                <ListBoxItem x:Name="HomeNavItem" Content="🏠 Trang Chủ" IsSelected="True"/>
                                <ListBoxItem x:Name="ProductsNavItem" Content="📦 Sản Phẩm" />
                                <ListBoxItem x:Name="CategoriesNavItem" Content="📂 Danh Mục"/>
                                <ListBoxItem x:Name="SuppliersNavItem" Content="🏭 Nhà Cung Cấp"/>
                                <ListBoxItem x:Name="InventoryNavItem" Content="📋 Quản Lý Kho"/>
                                <ListBoxItem x:Name="VouchersNavItem" Content="🎟️ Mã Giảm Giá"/>
                                <ListBoxItem x:Name="PromotionsNavItem" Content="🎁 Chương Trình KM"/>
                                <ListBoxItem x:Name="ProductSearchNavItem" Content="🔎 Tìm Kiếm Sản Phẩm" Visibility="Visible"/>
                                <ListBoxItem x:Name="CustomersNavItem" Content="👥 Khách Hàng"/>
                                <ListBoxItem x:Name="InvoicesNavItem" Content="🧾 Hóa Đơn"/>
                                <ListBoxItem x:Name="ShiftsNavItem" Content="⏰ Ca Làm Việc"/>
                                <ListBoxItem x:Name="ReportsNavItem" Content="📊 Báo Cáo"/>
                                <ListBoxItem x:Name="FinanceNavItem" Content="💰 Chi Phí &amp; Tài Chính"/>
                                <ListBoxItem x:Name="UserManagementNavItem" Content="👤 Quản Lý Người Dùng"/>
                                <ListBoxItem x:Name="SettingsNavItem" Content="⚙️ Cài Đặt"/>
                            </ListBox>
                        </StackPanel>
                    </ScrollViewer>
                    
                   
                </Grid>
            </Border>

            <!-- Right Content -->
            <Grid Grid.Column="1">
                <ScrollViewer x:Name="DefaultContentScrollViewer" VerticalScrollBarVisibility="Auto">
                    <Grid Margin="30">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                <!-- KPI Cards -->
                <Grid Grid.Row="0" Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <Border Background="White" CornerRadius="16" Padding="20" Margin="8" BorderBrush="#E2E8F0" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="💰 Doanh thu hôm nay" Foreground="#64748B" FontSize="12"/>
                            <TextBlock Text="{Binding RevenueTodayText}" FontSize="28" FontWeight="Bold" Foreground="#10B981"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="1" Background="White" CornerRadius="16" Padding="20" Margin="8" BorderBrush="#E2E8F0" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="📈 Doanh thu 30 ngày" Foreground="#64748B" FontSize="12"/>
                            <TextBlock Text="{Binding Revenue30Text}" FontSize="28" FontWeight="Bold" Foreground="#00AEEF"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="2" Background="White" CornerRadius="16" Padding="20" Margin="8" BorderBrush="#E2E8F0" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="🧾 Hóa đơn hôm nay" Foreground="#64748B" FontSize="12"/>
                            <TextBlock Text="{Binding InvoicesTodayText}" FontSize="28" FontWeight="Bold" Foreground="#EF4444"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="3" Background="White" CornerRadius="16" Padding="20" Margin="8" BorderBrush="#E2E8F0" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="👥 Khách hàng / Sản phẩm" Foreground="#64748B" FontSize="12"/>
                            <TextBlock Text="{Binding CountsText}" FontSize="28" FontWeight="Bold" Foreground="#FF9800"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Home charts - Row 1 -->
                <Grid Grid.Row="1" Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Background="White" CornerRadius="16" Padding="12" Margin="8" BorderBrush="#E2E8F0" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="📊 Doanh thu 30 ngày qua" FontWeight="SemiBold" Margin="0,0,0,8" Foreground="#1E293B"/>
                            <oxy:PlotView Model="{Binding HomeRevenuePlotModel}" Height="220" Background="Transparent"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="1" Background="White" CornerRadius="16" Padding="12" Margin="8" BorderBrush="#E2E8F0" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="🥧 Doanh thu theo danh mục" FontWeight="SemiBold" Margin="0,0,0,8" Foreground="#1E293B"/>
                            <oxy:PlotView Model="{Binding HomeCategoryPieModel}" Height="220" Background="Transparent"/>
                        </StackPanel>
                    </Border>
                </Grid>
 
                <!-- Home charts - Row 2 -->
                        <Grid Grid.Row="2" Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Background="White" CornerRadius="16" Padding="12" Margin="8" BorderBrush="#E2E8F0" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="👥 Top 10 Khách Hàng" FontWeight="SemiBold" Margin="0,0,0,8" Foreground="#1E293B"/>
                                    <oxy:PlotView Model="{Binding TopCustomersPlotModel}" Height="220" Background="Transparent"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="1" Background="White" CornerRadius="16" Padding="12" Margin="8" BorderBrush="#E2E8F0" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="🔥 Top 10 Sản Phẩm Bán Chạy" FontWeight="SemiBold" Margin="0,0,0,8" Foreground="#1E293B"/>
                                    <oxy:PlotView Model="{Binding TopProductsPlotModel}" Height="220" Background="Transparent"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Grid>
                </ScrollViewer>
                <ContentControl x:Name="MainContentHost" Visibility="Collapsed"/>
            </Grid>
        </Grid>
    </Grid>
</Window>
