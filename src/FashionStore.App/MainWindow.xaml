<Window x:Class="FashionStore.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:FashionStore.App.ViewModels"
        Title="Fashion Pro - Đăng Nhập" Height="550" Width="450"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        KeyDown="Window_KeyDown"
        Loaded="Window_Loaded">
    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>
    
    <Border CornerRadius="30" Background="#0F172A" BorderBrush="#D4AF37" BorderThickness="1">
        <Grid>
            <!-- Background Decoration -->
            <Ellipse Fill="#D4AF37" Width="200" Height="200" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-100,-100,0" Opacity="0.1"/>
            <Ellipse Fill="#334155" Width="150" Height="150" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="-75,0,0,-75" Opacity="0.2"/>

            <StackPanel Margin="40" VerticalAlignment="Center">
                <!-- Branding -->
                <Image Source="/Assets/logo.png" Width="180" Margin="0,0,0,30"/>
                
                <TextBlock Text="ĐĂNG NHẬP" 
                           Foreground="White" 
                           FontSize="24" 
                           FontWeight="Bold" 
                           HorizontalAlignment="Center" 
                           Margin="0,0,0,10"/>
                
                <TextBlock Text="Fashion Store Management System" 
                           Foreground="#94A3B8" 
                           FontSize="12" 
                           HorizontalAlignment="Center" 
                           Margin="0,0,0,35"/>

                <!-- Login Fields -->
                <TextBlock Text="Tên đăng nhập" Foreground="#94A3B8" Margin="5,0,0,5" FontSize="11" FontWeight="SemiBold"/>
                <Border Background="#1E293B" CornerRadius="12" Padding="10,2" Margin="0,0,0,15" BorderBrush="#334155" BorderThickness="1">
                    <TextBox x:Name="UsernameTextBox" 
                             Height="40" 
                             Background="Transparent" 
                             BorderThickness="0" 
                             Foreground="White" 
                             VerticalContentAlignment="Center" 
                             FontSize="15" 
                             Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"/>
                </Border>

                <TextBlock Text="Mật khẩu" Foreground="#94A3B8" Margin="5,0,0,5" FontSize="11" FontWeight="SemiBold"/>
                <Border Background="#1E293B" CornerRadius="12" Padding="10,2" Margin="0,0,0,30" BorderBrush="#334155" BorderThickness="1">
                    <PasswordBox x:Name="PasswordBox" 
                                 Height="40" 
                                 Background="Transparent" 
                                 BorderThickness="0" 
                                 Foreground="White" 
                                 VerticalContentAlignment="Center" 
                                 FontSize="15"/>
                </Border>

                <!-- Action Buttons -->
                <Button x:Name="LoginButton" 
                        Content="ĐĂNG NHẬP" 
                        Height="50" 
                        Background="#D4AF37" 
                        Foreground="#0F172A" 
                        FontWeight="ExtraBold" 
                        FontSize="16" 
                        Cursor="Hand"
                        Command="{Binding LoginCommand}"
                        CommandParameter="{Binding ElementName=PasswordBox}">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="12"/>
                        </Style>
                    </Button.Resources>
                </Button>

                <Button x:Name="ChangePasswordButton" 
                        Content="Quên mật khẩu / Đổi mật khẩu" 
                        Background="Transparent" 
                        BorderThickness="0" 
                        Foreground="#94A3B8" 
                        FontSize="12" 
                        Margin="0,15,0,0"
                        Cursor="Hand"
                        Command="{Binding OpenChangePasswordCommand}"
                        CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"/>
                </StackPanel>

            <!-- Close Button -->
            <Button Content="✕" 
                    HorizontalAlignment="Right" 
                    VerticalAlignment="Top" 
                    Margin="20" 
                    Background="Transparent" 
                    BorderThickness="0" 
                    Foreground="#94A3B8" 
                    FontSize="18"
                    Click="CloseButton_Click"/>
        </Grid>
    </Border>
</Window>
