@model IEnumerable<FashionStore.Core.Models.Customer>
@{
    ViewData["Title"] = "Quản lý khách hàng";
}

<div class="header-actions animate-in" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
    <div>
        <h1 class="gradient-text">Quản lý khách hàng</h1>
        <p style="color: var(--text-muted);">Theo dõi thành viên và phân hạng khách hàng.</p>
    </div>
    <div style="display: flex; gap: 1rem; align-items: center;">
        <a asp-action="ExportCsv" class="nav-link glass" style="padding: 0.5rem 1rem; border: none; font-weight: 600; color: var(--primary-color);">
            <i class="fas fa-file-export"></i> Xuất CSV
        </a>
        <form asp-action="ImportCsv" method="post" enctype="multipart/form-data" style="display: flex; align-items: center; gap: 0.5rem;">
            <label for="csvCustomerImport" style="cursor: pointer; color: var(--primary-color); font-size: 0.875rem; font-weight: 600;">
                <i class="fas fa-file-import"></i> Nhập CSV
            </label>
            <input type="file" id="csvCustomerImport" name="file" onchange="this.form.submit()" style="display: none;" accept=".csv" />
        </form>
        <a asp-action="Create" class="btn-primary" style="text-decoration: none; padding: 0.75rem 1.5rem;"><i class="fas fa-user-plus"></i> Thêm khách hàng</a>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="glass animate-in" style="background: rgba(16, 185, 129, 0.1); border-color: #10b981; color: #10b981; padding: 1rem; border-radius: 12px; margin-bottom: 2rem; display: flex; align-items: center; gap: 1rem;">
        <i class="fas fa-check-circle"></i> @TempData["Success"]
    </div>
}

<div class="glass animate-in" style="animation-delay: 0.1s; margin-bottom: 2rem; padding: 1.5rem; border: 1px solid var(--glass-border);">
    <form method="get" style="display: flex; gap: 1.5rem; align-items: flex-end; flex-wrap: wrap;">
        <div style="flex: 2; min-width: 300px;">
            <label style="display: block; margin-bottom: 0.5rem; font-size: 0.85rem; font-weight: 600; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.05em;">Tìm kiếm khách hàng</label>
            <div style="position: relative;">
                <i class="fas fa-search" style="position: absolute; left: 1rem; top: 50%; transform: translateY(-50%); color: var(--primary-color); opacity: 0.7;"></i>
                <input type="text" name="search" value="@ViewBag.CurrentSearch" placeholder="Tên, số điện thoại hoặc email..." 
                       style="width: 100%; padding: 0.75rem 1rem 0.75rem 2.8rem; border-radius: 12px; border: 1px solid var(--glass-border); background: rgba(255,255,255,0.03); color: var(--text-main); outline: none;" />
            </div>
        </div>
        <div style="width: 200px;">
            <label style="display: block; margin-bottom: 0.5rem; font-size: 0.85rem; font-weight: 600; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.05em;">Sắp xếp theo</label>
            <select name="sortBy" style="width: 100%; padding: 0.75rem; border-radius: 12px; border: 1px solid var(--glass-border); background: rgba(255,255,255,0.03); color: var(--text-main); outline: none; cursor: pointer;">
                <option value="id" selected="@(ViewBag.CurrentSortBy == "id")">Mặc định</option>
                <option value="name" selected="@(ViewBag.CurrentSortBy == "name")">Tên khách hàng</option>
                <option value="points" selected="@(ViewBag.CurrentSortBy == "points")">Điểm tích luỹ</option>
                <option value="spent" selected="@(ViewBag.CurrentSortBy == "spent")">Tổng chi tiêu</option>
                <option value="type" selected="@(ViewBag.CurrentSortBy == "type")">Hạng thành viên</option>
            </select>
        </div>
        <div style="width: 150px;">
            <label style="display: block; margin-bottom: 0.5rem; font-size: 0.85rem; font-weight: 600; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.05em;">Thứ tự</label>
            <select name="isDescending" style="width: 100%; padding: 0.75rem; border-radius: 12px; border: 1px solid var(--glass-border); background: rgba(255,255,255,0.03); color: var(--text-main); outline: none; cursor: pointer;">
                <option value="false" selected="@(ViewBag.IsDescending == false)">Tăng dần</option>
                <option value="true" selected="@(ViewBag.IsDescending == true)">Giảm dần</option>
            </select>
        </div>
        <div style="display: flex; gap: 0.75rem;">
            <button type="submit" class="btn-primary" style="padding: 0.75rem 1.5rem; height: 48px; border-radius: 12px; font-weight: 600;">
                <i class="fas fa-filter"></i> Lọc
            </button>
            <a asp-action="Index" class="nav-link glass" style="padding: 0.75rem 1rem; border-radius: 12px; display: flex; align-items: center; justify-content: center; height: 48px; border: none; background: rgba(255,255,255,0.05);">
                <i class="fas fa-sync-alt"></i>
            </a>
        </div>
    </form>
</div>

@if (TempData["Success"] != null)
{
    <div class="glass animate-in" style="background: rgba(16, 185, 129, 0.1); border-color: #10b981; color: #10b981; padding: 1rem; border-radius: 12px; margin-bottom: 2rem; display: flex; align-items: center; gap: 1rem;">
        <i class="fas fa-check-circle"></i> @TempData["Success"]
    </div>
}

<div class="glass animate-in" style="animation-delay: 0.15s;">
    <div class="table-container">
        <table>
            <thead>
                <tr>
                    <th>Khách hàng</th>
                    <th>Liên hệ</th>
                    <th>Phân hạng</th>
                    <th>Chi tiêu</th>
                    <th>Điểm</th>
                    <th>Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var customer in Model)
                {
                    <tr class="glass-hover-row">
                        <td>
                            <div style="font-weight: 600; color: var(--primary-color);">@customer.Name</div>
                            <div style="font-size: 0.75rem; color: var(--text-muted);">ID: #@customer.Id.ToString("D4")</div>
                        </td>
                        <td>
                            <div><i class="fas fa-phone-alt" style="font-size: 0.75rem; width: 15px;"></i> @customer.Phone</div>
                            <div style="font-size: 0.75rem; color: var(--text-muted);"><i class="fas fa-envelope" style="font-size: 0.75rem; width: 15px;"></i> @customer.Email</div>
                        </td>
                        <td>
                            @switch (customer.CustomerType)
                            {
                                case "VIP":
                                    <span style="background: linear-gradient(135deg, #f59e0b, #d97706); color: white; padding: 0.35rem 0.8rem; border-radius: 20px; font-size: 0.7rem; font-weight: 700; text-transform: uppercase;">VIP</span>
                                    break;
                                case "Gold":
                                    <span style="background: rgba(245, 158, 11, 0.15); color: #f59e0b; padding: 0.35rem 0.8rem; border-radius: 20px; font-size: 0.7rem; font-weight: 700; text-transform: uppercase; border: 1px solid rgba(245, 158, 11, 0.2);">Vàng</span>
                                    break;
                                case "Silver":
                                    <span style="background: rgba(148, 163, 184, 0.15); color: #94a3b8; padding: 0.35rem 0.8rem; border-radius: 20px; font-size: 0.7rem; font-weight: 700; text-transform: uppercase; border: 1px solid rgba(148, 163, 184, 0.2);">Bạc</span>
                                    break;
                                default:
                                    <span style="background: rgba(255, 255, 255, 0.05); color: var(--text-muted); padding: 0.35rem 0.8rem; border-radius: 20px; font-size: 0.7rem; font-weight: 600; text-transform: uppercase; border: 1px solid var(--glass-border);">Thường</span>
                                    break;
                            }
                        </td>
                        <td>
                            <div style="font-weight: 700; color: var(--primary-color);">@customer.TotalSpent.ToString("C0")</div>
                        </td>
                        <td style="font-weight: 700; color: #10b981;">@customer.Points.ToString("N0")</td>
                        <td>
                            <div style="display: flex; gap: 0.5rem;">
                                <a asp-action="Edit" asp-route-id="@customer.Id" class="nav-link glass" style="padding: 0.5rem; border: none; background: rgba(255,255,255,0.05); color: var(--text-muted);">
                                    <i class="fas fa-edit"></i>
                                </a>
                                <a asp-action="Details" asp-route-id="@customer.Id" class="nav-link glass" style="padding: 0.5rem; border: none; background: rgba(255,255,255,0.05); color: var(--text-muted);">
                                    <i class="fas fa-eye"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<style>
    .glass-hover-row:hover {
        background: rgba(255, 255, 255, 0.02);
    }
</style>
