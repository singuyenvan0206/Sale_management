@model IEnumerable<FashionStore.Core.Models.Invoice>
@{
    ViewData["Title"] = "Lịch sử hoá đơn";
}

<div class="header-actions animate-in" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
    <div>
        <h1 class="gradient-text">Lịch sử giao dịch</h1>
        <p style="color: var(--text-muted);">Quản lý và tra cứu tất cả hoá đơn đã lập.</p>
    </div>
    <div style="display: flex; gap: 1rem; align-items: center;">
        <div class="glass" style="display: flex; gap: 0.5rem; padding: 0.25rem 0.5rem; border-radius: 12px;">
            <a asp-action="ExportCsv" class="btn-link" style="color: var(--text-muted); padding: 0.5rem 1rem; text-decoration: none; font-size: 0.875rem;">
                <i class="fas fa-file-export"></i> Xuất CSV
            </a>
            <div style="width: 1px; background: var(--glass-border); margin: 0.5rem 0;"></div>
            <form asp-action="ImportCsv" method="post" enctype="multipart/form-data" style="display: flex; align-items: center; gap: 0.5rem; padding: 0 0.5rem;">
                <label for="csvImport" style="cursor: pointer; color: var(--primary-color); font-size: 0.875rem;">
                    <i class="fas fa-file-import"></i> Nhập CSV
                </label>
                <input type="file" id="csvImport" name="file" onchange="this.form.submit()" style="display: none;" accept=".csv" />
            </form>
        </div>
        
        <form method="get" style="display: flex; gap: 0.5rem;" class="glass" style="padding: 0.5rem; border-radius: 12px; border: 1px solid var(--glass-border); background: #fff;">
            <input type="text" name="search" placeholder="Số điện thoại / Tên khách..." style="background: transparent; border: none; color: var(--text-main); padding: 0.5rem; outline: none;" />
            <button type="submit" class="btn-primary" style="padding: 0.5rem 1rem;"><i class="fas fa-search"></i></button>
        </form>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="glass animate-in" style="background: rgba(16, 185, 129, 0.1); border-color: #10b981; color: #10b981; padding: 1rem; border-radius: 12px; margin-bottom: 2rem; display: flex; align-items: center; gap: 1rem;">
        <i class="fas fa-check-circle"></i> @TempData["Success"]
    </div>
}

<div class="glass animate-in" style="animation-delay: 0.1s;">
    <div class="table-container">
        <table id="invoiceTable">
            <thead>
                <tr>
                    <th>Mã HĐ</th>
                    <th>Thời gian</th>
                    <th>Khách hàng</th>
                    <th>Tổng tiền</th>
                    <th>Đã thanh toán</th>
                    <th>Trạng thái</th>
                    <th>Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var invoice in Model)
                {
                    <tr class="glass-hover-row">
                        <td style="font-weight: 600; color: var(--primary-color);">#@invoice.Id.ToString("D5")</td>
                        <td>@invoice.CreatedDate.ToString("dd/MM/yyyy HH:mm")</td>
                        <td>
                            <div>@invoice.CustomerName</div>
                            <div style="font-size: 0.75rem; color: var(--text-muted);">@invoice.CustomerPhone</div>
                        </td>
                        <td style="font-weight: 700;">@invoice.Total.ToString("C0")</td>
                        <td style="color: #10b981;">@invoice.Paid.ToString("C0")</td>
                        <td>
                            <span style="background: rgba(16, 185, 129, 0.1); color: #10b981; padding: 0.25rem 0.75rem; border-radius: 20px; font-size: 0.75rem; font-weight: 600;">
                                @invoice.Status
                            </span>
                        </td>
                        <td>
                            <a asp-action="Details" asp-route-id="@invoice.Id" class="nav-link" style="padding: 0.4rem; display: inline-flex; border: none; background: transparent;">
                                <i class="fas fa-eye"></i>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
