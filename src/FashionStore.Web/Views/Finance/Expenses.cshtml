@model IEnumerable<FashionStore.Core.Models.Expense>
@{
    ViewData["Title"] = "Quản lý chi phí";
}

<div class="header-actions animate-in" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
    <div>
        <h1 class="gradient-text">Quản lý chi phí doanh nghiệp</h1>
        <p style="color: var(--text-muted);">Ghi nhận các khoản chi ngoài bán hàng để tính toán lợi nhuận ròng.</p>
    </div>
    <div style="display: flex; gap: 1rem;">
        <button onclick="document.getElementById('addExpenseModal').style.display='flex'" class="btn-primary" style="padding: 0.75rem 1.5rem;">
            <i class="fas fa-plus"></i> Ghi nhận chi phí
        </button>
    </div>
</div>

<div class="dashboard-grid animate-in" style="display: grid; grid-template-columns: 1fr 3fr; gap: 1.5rem;">
    <div class="glass" style="padding: 1.5rem;">
        <h3>Bộ lọc & Tổng quan</h3>
        <form method="get" style="margin-top: 1.5rem; display: flex; flex-direction: column; gap: 1rem;">
            <div>
                <label style="display: block; font-size: 0.8rem; margin-bottom: 0.4rem;">Từ ngày</label>
                <input type="date" name="from" value="@ViewBag.From" class="glass" style="width: 100%; padding: 0.5rem; background: rgba(0,0,0,0.2); border: none; color: white;" />
            </div>
            <div>
                <label style="display: block; font-size: 0.8rem; margin-bottom: 0.4rem;">Đến ngày</label>
                <input type="date" name="to" value="@ViewBag.To" class="glass" style="width: 100%; padding: 0.5rem; background: rgba(0,0,0,0.2); border: none; color: white;" />
            </div>
            <button type="submit" class="btn-primary" style="width: 100%; margin-top: 0.5rem;">Lọc dữ liệu</button>
        </form>

        <div style="margin-top: 2rem; padding-top: 1.5rem; border-top: 1px solid var(--glass-border);">
            <div style="font-size: 0.9rem; color: var(--text-muted);">Tổng chi phí kỳ này:</div>
            <div style="font-size: 1.8rem; font-weight: 800; color: #ef4444;">@ViewBag.Total.ToString("C0")</div>
        </div>
    </div>

    <div class="glass" style="padding: 1.5rem;">
        <div class="table-container">
            <table>
                <thead>
                    <tr>
                        <th>Ngày</th>
                        <th>Hạng mục</th>
                        <th>Số tiền</th>
                        <th>Mô tả</th>
                        <th>Người tạo</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var expense in Model)
                    {
                        <tr class="glass-hover-row">
                            <td>@expense.CreatedDate.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>
                                <span style="background: rgba(255,255,255,0.05); padding: 0.2rem 0.6rem; border-radius: 4px; font-size: 0.8rem;">
                                    @expense.Category
                                </span>
                            </td>
                            <td style="font-weight: 700; color: #ef4444;">@expense.Amount.ToString("C0")</td>
                            <td style="font-size: 0.85rem; color: var(--text-muted);">@expense.Description</td>
                            <td>@expense.EmployeeName</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Add Expense Modal -->
<div id="addExpenseModal" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.8); z-index: 1000; align-items: center; justify-content: center;">
    <div class="glass" style="width: 500px; padding: 2rem; border: 1px solid var(--primary-color);">
        <h2 class="gradient-text" style="margin-bottom: 1.5rem;">Ghi nhận chi phí mới</h2>
        <form asp-action="AddExpense" method="post" style="display: flex; flex-direction: column; gap: 1.25rem;">
            <div>
                <label>Hạng mục chi phí</label>
                <select name="Category" class="glass" style="width: 100%; padding: 0.75rem; background: var(--bg-color); color: white; margin-top: 0.5rem;" required>
                    <option value="Tiền thuê mặt bằng">Tiền thuê mặt bằng</option>
                    <option value="Điện & Nước">Điện & Nước</option>
                    <option value="Lương nhân viên">Lương nhân viên</option>
                    <option value="Marketing & Quảng cáo">Marketing & Quảng cáo</option>
                    <option value="Vật tư & Văn phòng phẩm">Vật tư & Văn phòng phẩm</option>
                    <option value="Khác">Chi phí khác</option>
                </select>
            </div>
            <div>
                <label>Số tiền (VNĐ)</label>
                <input type="number" name="Amount" class="glass" style="width: 100%; padding: 0.75rem; background: var(--bg-color); color: white; margin-top: 0.5rem;" required min="1000" />
            </div>
            <div>
                <label>Mô tả chi tiết</label>
                <textarea name="Description" class="glass" style="width: 100%; padding: 0.75rem; background: var(--bg-color); color: white; margin-top: 0.5rem;" rows="3"></textarea>
            </div>
            <div style="display: flex; gap: 1rem; margin-top: 1rem;">
                <button type="button" onclick="document.getElementById('addExpenseModal').style.display='none'" class="nav-link glass" style="flex: 1; border: none; text-align: center;">Hủy</button>
                <button type="submit" class="btn-primary" style="flex: 1;">Lưu chi phí</button>
            </div>
        </form>
    </div>
</div>
