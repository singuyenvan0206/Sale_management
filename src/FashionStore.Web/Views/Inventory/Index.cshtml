@using FashionStore.Core.Models
@model dynamic
@{
    ViewData["Title"] = "Quản lý Kho";
    var currentTab = ViewBag.CurrentTab as string ?? "history";
    var productsMap = ViewBag.ProductsMap as Dictionary<int, string>;
    var suppliers = ViewBag.Suppliers as IEnumerable<Supplier>;
    var allProducts = ViewBag.AllProducts as IEnumerable<Product>;
}

<div class="header-actions animate-in" style="margin-bottom: 2rem;">
    <div>
        <h1 class="gradient-text">Trung tâm Quản lý Kho</h1>
        <p style="color: var(--text-muted);">Theo dõi biến động, quản lý đơn nhập và tối ưu chuỗi cung ứng.</p>
    </div>
</div>

<!-- Navigation Tabs -->
<div class="glass animate-in" style="padding: 0.5rem; display: flex; gap: 0.5rem; margin-bottom: 1.5rem; border-radius: 15px;">
    <a asp-action="Index" asp-route-tab="history" class="nav-link @(currentTab == "history" ? "active" : "")" style="flex: 1; text-align: center; padding: 0.75rem; border-radius: 10px; text-decoration: none;">
        <i class="fas fa-history"></i> Biến động kho
    </a>
    <a asp-action="Index" asp-route-tab="po" class="nav-link @(currentTab == "po" ? "active" : "")" style="flex: 1; text-align: center; padding: 0.75rem; border-radius: 10px; text-decoration: none;">
        <i class="fas fa-truck-loading"></i> Đơn nhập hàng (PO)
    </a>
    <a asp-action="Index" asp-route-tab="import" class="nav-link @(currentTab == "import" ? "active" : "")" style="flex: 1; text-align: center; padding: 0.75rem; border-radius: 10px; text-decoration: none;">
        <i class="fas fa-plus-circle"></i> Nhập hàng nhanh
    </a>
</div>

@if (currentTab == "history")
{
    var movements = Model as IEnumerable<StockMovement>;
    <div class="glass animate-in" style="animation-delay: 0.1s;">
        <div class="table-container">
            <table>
                <thead>
                    <tr>
                        <th>Thời gian</th>
                        <th>Sản phẩm</th>
                        <th>Loại</th>
                        <th>Số lượng</th>
                        <th>Trước</th>
                        <th>Sau</th>
                        <th>Ghi chú</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var move in movements)
                    {
                        <tr class="glass-hover-row">
                            <td>@move.CreatedDate.ToString("dd/MM/yyyy HH:mm")</td>
                            <td style="font-weight: 600;">@(productsMap != null && productsMap.ContainsKey(move.ProductId) ? productsMap[move.ProductId] : "N/A")</td>
                            <td>
                                @switch (move.MovementType)
                                {
                                    case "Import": <span style="color: #10b981;"><i class="fas fa-arrow-down"></i> Nhập</span> break;
                                    case "Sale": <span style="color: #6366f1;"><i class="fas fa-arrow-up"></i> Bán</span> break;
                                    case "Adjustment": <span style="color: #f59e0b;"><i class="fas fa-sync"></i> Điều chỉnh</span> break;
                                    default: <span>@move.MovementType</span> break;
                                }
                            </td>
                            <td style="font-weight: 700;">@move.Quantity</td>
                            <td>@move.PreviousStock</td>
                            <td style="font-weight: 600;">@move.NewStock</td>
                            <td style="font-size: 0.75rem; color: var(--text-muted);">@move.Notes</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
else if (currentTab == "po")
{
    var orders = Model as IEnumerable<PurchaseOrder>;
    <div class="glass animate-in" style="animation-delay: 0.1s;">
        <div class="table-container">
            <table>
                <thead>
                    <tr>
                        <th>Mã đơn</th>
                        <th>Ngày tạo</th>
                        <th>Nhà cung cấp</th>
                        <th>Tổng tiền</th>
                        <th>Trạng thái</th>
                        <th>Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var po in orders)
                    {
                        <tr class="glass-hover-row">
                            <td style="font-weight: 600; color: var(--primary-color);">#PO-@po.Id.ToString("D5")</td>
                            <td>@po.CreatedDate.ToString("dd/MM/yyyy")</td>
                            <td>@po.SupplierName</td>
                            <td style="font-weight: 700;">@po.TotalAmount.ToString("C0")</td>
                            <td>
                                <span style="padding: 0.25rem 0.75rem; border-radius: 20px; font-size: 0.75rem; font-weight: 600; background: rgba(148,163,184,0.1);">
                                    @po.Status
                                </span>
                            </td>
                            <td>
                                <a asp-action="PODetails" asp-route-id="@po.Id" class="nav-link"><i class="fas fa-eye"></i></a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
else if (currentTab == "import")
{
    <div class="glass animate-in" style="padding: 2rem;">
        <h3 style="margin-bottom: 1.5rem;"><i class="fas fa-bolt"></i> Nhập kho nhanh</h3>
        <div class="dashboard-grid" style="display: grid; grid-template-columns: 1fr 2fr; gap: 2rem;">
             <div class="glass" style="padding: 1.5rem; background: rgba(255,255,255,0.02);">
                <div class="form-group">
                    <label>Nhà cung cấp</label>
                    <select id="supplierId" class="glass-input">
                        @foreach (var s in suppliers) { <option value="@s.Id">@s.Name</option> }
                    </select>
                </div>
                <div class="form-group" style="margin-top: 1rem;">
                    <label>Ghi chú</label>
                    <textarea id="importNotes" class="glass-input" rows="3" placeholder="Lý do nhập hàng..."></textarea>
                </div>
                <button onclick="submitImport()" class="btn-primary" style="width: 100%; margin-top: 2rem;">
                    <i class="fas fa-check"></i> Hoàn tất nhập kho
                </button>
            </div>

            <div class="glass" style="padding: 1.5rem; background: rgba(255,255,255,0.02);">
                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem;">
                    <h4 style="margin: 0;">Danh sách mặt hàng</h4>
                    <button onclick="addRow()" class="btn-secondary" style="font-size: 0.8rem; padding: 0.4rem 0.8rem;">
                        <i class="fas fa-plus"></i> Thêm dòng
                    </button>
                </div>
                <div class="table-container">
                    <table>
                        <thead>
                            <tr>
                                <th>Sản phẩm</th>
                                <th style="width: 100px;">S.Lượng</th>
                                <th style="width: 150px;">Giá nhập</th>
                                <th style="width: 50px;"></th>
                            </tr>
                        </thead>
                        <tbody id="importItemsTable">
                            <tr class="import-row">
                                <td>
                                    <select class="glass-input product-select">
                                        @foreach (var p in allProducts) { <option value="@p.Id">@p.Name (@p.Code)</option> }
                                    </select>
                                </td>
                                <td><input type="number" class="glass-input qty-input" value="1" min="1" /></td>
                                <td><input type="number" class="glass-input price-input" value="0" /></td>
                                <td><button onclick="removeRow(this)" style="background: none; border: none; color: #ef4444;"><i class="fas fa-times"></i></button></td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    @section Scripts {
        <script>
            function addRow() {
                const tbody = document.getElementById('importItemsTable');
                const row = tbody.rows[0].cloneNode(true);
                row.querySelector('.qty-input').value = 1;
                row.querySelector('.price-input').value = 0;
                tbody.appendChild(row);
            }

            function removeRow(btn) {
                const tbody = document.getElementById('importItemsTable');
                if (tbody.rows.length > 1) {
                    btn.closest('tr').remove();
                }
            }

            async function submitImport() {
                const request = {
                    supplierId: parseInt(document.getElementById('supplierId').value),
                    notes: document.getElementById('importNotes').value,
                    items: []
                };

                document.querySelectorAll('.import-row').forEach(row => {
                    request.items.push({
                        productId: parseInt(row.querySelector('.product-select').value),
                        quantity: parseInt(row.querySelector('.qty-input').value),
                        unitPrice: parseFloat(row.querySelector('.price-input').value)
                    });
                });

                const response = await fetch('/Inventory/ProcessImport', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(request)
                });

                if (response.ok) {
                    alert('Nhập hàng thành công và đã cập nhật kho!');
                    window.location.href = '/Inventory/Index?tab=po';
                } else {
                    alert('Đã xảy ra lỗi khi nhập hàng.');
                }
            }
        </script>
    }
}
