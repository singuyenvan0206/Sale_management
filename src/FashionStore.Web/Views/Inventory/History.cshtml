@model IEnumerable<FashionStore.Core.Models.StockMovement>
@{
    ViewData["Title"] = "Lịch sử kho";
    var products = ViewBag.Products as Dictionary<int, string>;
}

<div class="header-actions animate-in" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
    <div>
        <h1 class="gradient-text">Lịch sử biến động kho</h1>
        <p style="color: var(--text-muted);">Theo dõi dấu kiểm toán cho tất cả thay đổi tồn kho.</p>
    </div>
    <div style="display: flex; gap: 1rem;">
        <a asp-action="Import" class="btn-primary" style="text-decoration: none;"><i class="fas fa-plus"></i> Nhập hàng mới</a>
    </div>
</div>

<div class="glass animate-in" style="animation-delay: 0.1s;">
    <div class="table-container">
        <table>
            <thead>
                <tr>
                    <th>Thời gian</th>
                    <th>Sản phẩm</th>
                    <th>Loại</th>
                    <th>Số lượng</th>
                    <th>Trước</th>
                    <th>Sau</th>
                    <th>Ghi chú</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var move in Model)
                {
                    <tr class="glass-hover-row">
                        <td style="font-size: 0.875rem;">@move.CreatedDate.ToString("dd/MM/yyyy HH:mm")</td>
                        <td style="font-weight: 600;">@(products != null && products.ContainsKey(move.ProductId) ? products[move.ProductId] : "N/A")</td>
                        <td>
                            @switch (move.MovementType)
                            {
                                case "Import":
                                    <span style="color: #10b981; font-weight: 700;"><i class="fas fa-arrow-down"></i> Nhập</span>
                                    break;
                                case "Sale":
                                    <span style="color: #6366f1; font-weight: 700;"><i class="fas fa-arrow-up"></i> Bán</span>
                                    break;
                                case "Adjustment":
                                    <span style="color: #f59e0b; font-weight: 700;"><i class="fas fa-sync"></i> Điều chỉnh</span>
                                    break;
                                default:
                                    <span>@move.MovementType</span>
                                    break;
                            }
                        </td>
                        <td style="font-weight: 700;">@move.Quantity</td>
                        <td style="color: var(--text-muted);">@move.PreviousStock</td>
                        <td style="font-weight: 600;">@move.NewStock</td>
                        <td style="font-size: 0.75rem; color: var(--text-muted); max-width: 200px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;" title="@move.Notes">@move.Notes</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
