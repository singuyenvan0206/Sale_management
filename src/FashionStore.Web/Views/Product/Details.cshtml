@model FashionStore.Core.Models.Product
@{
    ViewData["Title"] = "Chi tiết sản phẩm";
}

<div class="header-actions animate-in" style="margin-bottom: 2rem;">
    <div style="display: flex; justify-content: space-between; align-items: flex-start;">
        <div>
            <a asp-action="Index" class="nav-link" style="display: inline-block; margin-bottom: 0.5rem; color: var(--text-muted);">
                <i class="fas fa-arrow-left"></i> Quay lại danh sách
            </a>
            <h1 class="gradient-text">@Model.Name</h1>
            <p style="color: var(--text-muted);">Mã sản phẩm: <strong style="color: var(--primary-color);">@Model.Code</strong></p>
        </div>
        @if (User.IsInRole("Admin") || User.IsInRole("Manager"))
        {
            <div style="display: flex; gap: 1rem;">
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn-primary" style="background: rgba(255,255,255,0.05); color: white; border: 1px solid var(--glass-border);">
                    <i class="fas fa-edit"></i> Chỉnh sửa thông tin
                </a>
            </div>
        }
    </div>
</div>

<div class="product-grid" style="display: grid; grid-template-columns: 350px 1fr; gap: 2rem;">
    <!-- Left: QR & Image -->
    <div class="animate-in" style="animation-delay: 0.1s;">
        <div class="glass" style="padding: 1.5rem; text-align: center; margin-bottom: 1.5rem;">
            <div id="product-qrcode" style="display: flex; justify-content: center; margin-bottom: 1rem; padding: 1rem; background: white; border-radius: 12px; width: fit-content; margin-left: auto; margin-right: auto;"></div>
            <p style="font-size: 0.85rem; color: var(--text-muted);">Quét để xem thông tin sản phẩm hoặc thanh toán tại quầy.</p>
            <button onclick="printQRCode('product-qrcode', '@Model.Name')" class="nav-link glass" style="margin-top: 1rem; width: 100%; border: none; padding: 0.5rem;">
                <i class="fas fa-print"></i> In nhãn mã QR
            </button>
        </div>

        <div class="glass" style="padding: 1.5rem;">
            <h3 style="margin-bottom: 1rem; font-size: 1rem;">Thông tin cơ bản</h3>
            <div style="display: flex; flex-direction: column; gap: 0.75rem; font-size: 0.9rem;">
                <div style="display: flex; justify-content: space-between;">
                    <span style="color: var(--text-muted);">Danh mục:</span>
                    <span>@Model.CategoryName</span>
                </div>
                <div style="display: flex; justify-content: space-between;">
                    <span style="color: var(--text-muted);">Giá bán:</span>
                    <span style="font-weight: 700; color: var(--primary-color);">@Model.SalePrice.ToString("C0")</span>
                </div>
                @if (User.IsInRole("Admin") || User.IsInRole("Manager"))
                {
                    <div style="display: flex; justify-content: space-between;">
                        <span style="color: var(--text-muted);">Giá nhập:</span>
                        <span>@Model.PurchasePrice.ToString("C0")</span>
                    </div>
                }
                <div style="display: flex; justify-content: space-between;">
                    <span style="color: var(--text-muted);">Tổng tồn kho:</span>
                    <span style="font-weight: 600;">@Model.Variants.Sum(v => v.StockQuantity)</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Right: Variants Management -->
    <div class="animate-in" style="animation-delay: 0.2s;">
        <div class="glass" style="padding: 1.5rem;">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem;">
                <h3 style="margin: 0;">Biến thể sản phẩm (Size / Màu sắc)</h3>
                @if (User.IsInRole("Admin") || User.IsInRole("Manager"))
                {
                    <button onclick="showAddVariantModal()" class="btn-primary" style="padding: 0.5rem 1rem; font-size: 0.9rem;">
                        <i class="fas fa-plus"></i> Thêm biến thể
                    </button>
                }
            </div>

            <div class="table-container">
                <table>
                    <thead>
                        <tr>
                            <th>Size</th>
                            <th>Màu sắc</th>
                            <th>SKU / Barcode</th>
                            <th>Tồn kho</th>
                            @if (User.IsInRole("Admin") || User.IsInRole("Manager"))
                            {
                                <th>Thao tác</th>
                            }
                        </tr>
                    </thead>
                    <tbody id="variant-table-body">
                        @if (Model.Variants != null && Model.Variants.Any())
                        {
                            foreach (var variant in Model.Variants)
                            {
                                <tr id="variant-row-@variant.Id">
                                    <td><strong>@variant.Size</strong></td>
                                    <td>@variant.Color</td>
                                    <td style="font-family: monospace;">@variant.Barcode</td>
                                    <td>
                                        <span class="stock-badge @(variant.StockQuantity <= 5 ? "low" : "")">
                                            @variant.StockQuantity
                                        </span>
                                    </td>
                                    @if (User.IsInRole("Admin") || User.IsInRole("Manager"))
                                    {
                                        <td>
                                            <div style="display: flex; gap: 0.5rem;">
                                                <button onclick="deleteVariant(@variant.Id)" class="nav-link" style="color: #ef4444; border: none; background: none; cursor: pointer;">
                                                    <i class="fas fa-trash"></i>
                                                </button>
                                            </div>
                                        </td>
                                    }
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" style="text-align: center; color: var(--text-muted); padding: 2rem;">Chưa có biến thể nào. Hãy thêm Size hoặc Màu sắc.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Add Variant Modal -->
<div id="addVariantModal" class="modal-overlay" style="display: none;">
    <div class="glass modal-content animate-in" style="max-width: 500px; padding: 2rem;">
        <h2 class="gradient-text" style="margin-top: 0;">Thêm biến thể mới</h2>
        <div style="display: grid; gap: 1rem; margin-top: 1.5rem;">
            <div class="form-group">
                <label>Size (VD: S, M, L, 39, 40...)</label>
                <input type="text" id="v-size" placeholder="Nhập size" class="glass-input" />
            </div>
            <div class="form-group">
                <label>Màu sắc</label>
                <input type="text" id="v-color" placeholder="Nhập màu" class="glass-input" />
            </div>
            <div class="form-group">
                <label>Mã vạch / Barcode (Nếu có)</label>
                <input type="text" id="v-barcode" value="@Model.Code-@(Model.Variants.Count + 1)" class="glass-input" />
            </div>
            <div class="form-group">
                <label>Số lượng tồn ban đầu</label>
                <input type="number" id="v-stock" value="0" class="glass-input" />
            </div>
            <div style="display: flex; gap: 1rem; margin-top: 1rem;">
                <button onclick="submitVariant()" class="btn-primary" style="flex: 1;">Xác nhận</button>
                <button onclick="closeAddVariantModal()" class="btn-secondary" style="flex: 1;">Hủy</button>
            </div>
        </div>
    </div>
</div>

<style>
    .stock-badge {
        background: rgba(16, 185, 129, 0.1);
        color: #10b981;
        padding: 0.2rem 0.6rem;
        border-radius: 6px;
        font-weight: 600;
    }
    .stock-badge.low {
        background: rgba(239, 68, 68, 0.1);
        color: #ef4444;
    }
    .modal-overlay {
        position: fixed;
        top: 0; left: 0; right: 0; bottom: 0;
        background: rgba(0,0,0,0.8);
        backdrop-filter: blur(8px);
        z-index: 1000;
        display: flex; align-items: center; justify-content: center;
    }
    .modal-content { border: 1px solid var(--glass-border); width: 90%; }
</style>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Generate Main Product QR
            new QRCode(document.getElementById("product-qrcode"), {
                text: "@Model.Code",
                width: 150,
                height: 150,
                colorDark : "#000000",
                colorLight : "#ffffff",
                correctLevel : QRCode.CorrectLevel.H
            });
        });

        function showAddVariantModal() {
            document.getElementById('addVariantModal').style.display = 'flex';
        }

        function closeAddVariantModal() {
            document.getElementById('addVariantModal').style.display = 'none';
        }

        async function submitVariant() {
            const variant = {
                productId: @Model.Id,
                size: document.getElementById('v-size').value,
                color: document.getElementById('v-color').value,
                barcode: document.getElementById('v-barcode').value,
                stockQuantity: parseInt(document.getElementById('v-stock').value) || 0
            };

            if (!variant.size && !variant.color) {
                alert("Vui lòng nhập Size hoặc Màu sắc");
                return;
            }

            try {
                const response = await fetch('/Product/AddVariant', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(variant)
                });

                if (response.ok) {
                    location.reload();
                } else {
                    alert("Lỗi khi thêm biến thể");
                }
            } catch (err) {
                console.error(err);
                alert("Lỗi kết nối");
            }
        }

        async function deleteVariant(id) {
            if (!confirm("Bạn có chắc chắn muốn xóa biến thể này?")) return;

            try {
                const response = await fetch(`/Product/DeleteVariant?id=${id}`, {
                    method: 'POST'
                });

                if (response.ok) {
                    document.getElementById(`variant-row-${id}`).remove();
                } else {
                    alert("Lỗi khi xóa biến thể");
                }
            } catch (err) {
                console.error(err);
                alert("Lỗi kết nối");
            }
        }

        function printQRCode(elementId, label) {
            const qrCanvas = document.querySelector(`#${elementId} canvas`);
            if (!qrCanvas) return;
            
            const dataUrl = qrCanvas.toDataURL();
            const windowContent = `
                <!DOCTYPE html>
                <html>
                <head><title>Print QR</title></head>
                <body style="text-align: center; font-family: sans-serif; padding-top: 50px;">
                    <h2>${label}</h2>
                    <img src="${dataUrl}" style="width: 200px; height: 200px;" />
                    <p style="margin-top: 10px; font-weight: bold;">@Model.Code</p>
                    <script>window.onload = function() { window.print(); window.close(); }<\/script>
                </body>
                </html>
            `;
            const printWin = window.open('', '', 'width=600,height=600');
            printWin.document.open();
            printWin.document.write(windowContent);
            printWin.document.close();
        }
    </script>
}
